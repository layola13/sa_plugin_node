@test "node.readline create and free succeeds"():
L_ENTRY:
    rl = add 0, 0
    s = add 0, 0
    EXPAND NODE_READLINE_CREATE rl
    EXPAND NODE_READLINE_FREE rl, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    !rl
    return
L_ERR:
    !ok
    !s
    !rl
    panic(103)

@test "node.readline clear_line succeeds"():
L_ENTRY:
