// SA tests for Node trace_events extras
@import "../node.sal"
@import "../node_extra.sal"
@const S_CAT = utf8:"test-cat"

@test "node.trace_events create and free"():
L_ENTRY:
    t = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_TRACE_EVENTS_CREATE_TRACING S_CAT, 8, t
    EXPAND NODE_TRACE_EVENTS_TRACING_FREE t
    !s2
    !s1
    !t
    return

@test "node.trace_events enable and disable"():
L_ENTRY:
    t = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    s3 = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_TRACE_EVENTS_CREATE_TRACING S_CAT, 8, t
    EXPAND NODE_TRACE_EVENTS_TRACING_ENABLE t
    EXPAND NODE_TRACE_EVENTS_TRACING_DISABLE t
    EXPAND NODE_TRACE_EVENTS_TRACING_FREE t
    !s4
    !s3
    !s2
    !s1
    !t
    return
