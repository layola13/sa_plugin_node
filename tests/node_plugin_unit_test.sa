// SA-native unit tests for the Node compatibility plugin.
// These tests use the SA @test framework directly and exercise the Zig plugin API.
@import "../node.sal"
@import "../node_extra.sal"

@const S_SHA256 = utf8:"sha256"
@const S_HELLO = utf8:"hello"
@const S_SECRET = utf8:"secret123"
@const S_URL = utf8:"https://example.com/path?q=1"
@const S_ENCODED = utf8:"hello%20world"
@const S_PATH = utf8:"/usr/local/bin/test.txt"
@const S_FROM = utf8:"/usr/local/bin"
@const S_TO = utf8:"/usr/local/share"
@const S_FMT = utf8:"hello %s"
@const S_ARGS = utf8:"[\"world\"]"
@const S_JSON_A = utf8:"{\"a\":1}"
@const S_VT = utf8:"\x1b[31mred\x1b[0m"
@const S_IP4 = utf8:"127.0.0.1"
@const S_IP6 = utf8:"::1"
@const S_NOTIP = utf8:"not-ip"
@const S_DOMAIN = utf8:"example.com"
@const S_LOG = utf8:"log msg"
@const S_LABEL = utf8:"sa_unit_timer"
@const S_KEY = utf8:"SA_NODE_UNIT_KEY"
@const S_VAL = utf8:"unit_value"
@const S_QS = utf8:"a=1&b=two"
@const S_PATH_JSON = utf8:"{\"dir\":\"/tmp\",\"base\":\"x.txt\"}"
@const S_URL_JSON = utf8:"{\"protocol\":\"https:\",\"host\":\"example.com\",\"pathname\":\"/p\"}"
@const S_EVENT = utf8:"event"
@const S_DATA = utf8:"data"
@const S_PLUGIN_FILE = utf8:"/home/vscode/projects/sa_plugins/sa_plugin_node/sap.json"
@const S_PLUGIN_DIR = utf8:"/home/vscode/projects/sa_plugins/sa_plugin_node"

@test "node.os freemem succeeds"():
L_ENTRY:
    EXPAND NODE_OS_FREEMEM m, s
    ok = eq s, 0
    br ok -> L_OK, L_STATUS_ERR
L_OK:
    !ok
    !m
    !s
    return
L_STATUS_ERR:
    !ok
    !m
    !s
    panic(103)

@test "node.os homedir returns bytes"():
L_ENTRY:
    EXPAND NODE_OS_HOMEDIR p, l, s
    ok = eq s, 0
    br ok -> L_STATUS_OK, L_STATUS_ERR
L_STATUS_OK:
    !ok
    !s
    non_empty = ugt l, 0
    br non_empty -> L_FREE, L_LEN_ERR
L_FREE:
    !non_empty
    EXPAND NODE_FREE_BUFFER p, l, fs
    free_ok = eq fs, 0
    br free_ok -> L_OK, L_FREE_ERR
L_OK:
    !free_ok
    !fs
    !p
    !l
    return
L_STATUS_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !non_empty
    !p
    !l
    panic(103)
L_FREE_ERR:
    !free_ok
    !fs
    !p
    !l
    panic(103)

