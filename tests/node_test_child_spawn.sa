// SA tests for Node child_process: spawn_sync, exec_file
@import "../node.sal"
@import "../node_extra.sal"
@const S_LS = utf8:"ls"

@test "node.child_process spawn_sync"():
L_ENTRY:
    argv = stack_alloc 16
    store argv+0, S_LS as ptr
    store argv+8, 2 as u64
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_CHILD_PROCESS_SPAWN_SYNC argv, 1, 0, 0, op, ol, s
    !s
    !ol
    !op
    return

@test "node.child_process exec_file"():
L_ENTRY:
    argv = stack_alloc 16
    store argv+0, S_LS as ptr
    store argv+8, 2 as u64
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_CHILD_PROCESS_EXEC_FILE argv, 1, 0, 0, op, ol, s
    !s
    !ol
    !op
    return
