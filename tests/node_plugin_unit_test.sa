@test "node.process env set get delete"():
L_ENTRY:
    EXPAND NODE_PROCESS_ENV_SET S_KEY, 16, S_VAL, 10, s1
    ok1 = eq s1, 0
    br ok1 -> L_SET_OK, L_SET_ERR
L_SET_OK:
    !ok1
    !s1
    EXPAND NODE_PROCESS_ENV_GET S_KEY, 16, p, l, s2
    ok2 = eq s2, 0
    br ok2 -> L_GET_OK, L_GET_ERR
L_GET_OK:
    !ok2
    !s2
    value_len = eq l, 10
    br value_len -> L_DELETE, L_LEN_ERR
L_DELETE:
    !value_len
    EXPAND NODE_PROCESS_ENV_DELETE S_KEY, 16, s3
    ok3 = eq s3, 0
    br ok3 -> L_OK, L_DELETE_ERR
L_OK:
    !ok3
    !s3
    !p
    !l
    return
L_SET_ERR:
    !ok1
    !s1
    panic(103)
L_GET_ERR:
    !ok2
    !p
    !l
    !s2
    panic(103)
L_LEN_ERR:
    !value_len
    !p
    !l
    panic(103)
L_DELETE_ERR:
    !ok3
    !s3
    !p
    !l
    panic(103)

