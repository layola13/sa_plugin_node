// ============================================================
// Events
// ============================================================

@test "events.create and free"():
    EXPAND NODE_EVENTS_CREATE ee
    !ee
    EXPAND NODE_EVENTS_FREE ee, fs
    !ee
    !fs
    return

@test "events.on and emit"():
    EXPAND NODE_EVENTS_CREATE ee
    EXPAND NODE_EVENTS_ON ee, S_HELLO 5, 0, os1
    EXPAND NODE_EVENTS_EMIT ee, S_HELLO 5, S_HELLO 5, es
    !ee
    !os1
    !es
    return

@test "events.listenerCount"():
    EXPAND NODE_EVENTS_CREATE ee
    EXPAND NODE_EVENTS_ON ee, S_HELLO 5, 0, os1
    EXPAND NODE_EVENTS_LISTENER_COUNT ee, S_HELLO 5, cnt, lc
    !ee
    !os1
    !cnt
    !lc
    return

