    const home = std.posix.getenv("HOME") orelse "/home/vscode";
    const owned = std.heap.page_allocator.dupe(u8, home) catch return 2;
    out_ptr.?.* = owned.ptr;
    out_len.?.* = owned.len;
    return 0;
}

