// SA tests for Node inspector top-level facade helpers
@import "../node.sal"

@test "node.inspector top level helpers"():
L_ENTRY:
    status_ptr = add 0, 0
    status_len = add 0, 0
    EXPAND NODE_INSPECTOR_STATUS_JSON status_ptr, status_len
    has_status = ugt status_len, 0
    br has_status -> L_EXPORTS, L_ERR_STATUS
L_EXPORTS:
    !has_status
    exports_ptr = add 0, 0
    exports_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_INSPECTOR_EXPORTS_JSON exports_ptr, exports_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_ENABLED, L_ERR_EXPORTS
L_ENABLED:
    !ok2
    enabled = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_INSPECTOR_IS_ENABLED enabled, s3
    ok3 = eq s3, 0
    br ok3 -> L_ALLOWED, L_ERR_ENABLED
L_ALLOWED:
    !ok3
    allowed = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_INSPECTOR_IS_ALLOWED allowed, s4
    ok4 = eq s4, 0
    br ok4 -> L_CONFIG, L_ERR_ALLOWED
L_CONFIG:
    !ok4
    config_ptr = add 0, 0
    config_len = add 0, 0
    s5 = add 0, 0
    EXPAND NODE_INSPECTOR_CONFIG_JSON config_ptr, config_len, s5
    ok5 = eq s5, 0
    br ok5 -> L_URL, L_ERR_CONFIG
L_URL:
    !ok5
    url_ptr = add 0, 0
    url_len = add 0, 0
    s6 = add 0, 0
    EXPAND NODE_INSPECTOR_URL_JSON url_ptr, url_len, s6
    ok6 = eq s6, 0
    br ok6 -> L_FEATURES, L_ERR_URL
L_FEATURES:
    !ok6
    feature_ptr = add 0, 0
    feature_len = add 0, 0
    s7 = add 0, 0
    EXPAND NODE_INSPECTOR_FEATURE_SUPPORT_JSON feature_ptr, feature_len, s7
    ok7 = eq s7, 0
    br ok7 -> L_FREE, L_ERR_FEATURES
L_FREE:
    !ok7
    free_feature = call @sa_node_plugin_free_buffer(feature_ptr, feature_len)
    free_url = call @sa_node_plugin_free_buffer(url_ptr, url_len)
    free_config = call @sa_node_plugin_free_buffer(config_ptr, config_len)
    free_exports = call @sa_node_plugin_free_buffer(exports_ptr, exports_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_exports
    !free_config
    !free_url
    !free_feature
    !s7
    !feature_len
    !feature_ptr
    !s6
    !url_len
    !url_ptr
    !s5
    !config_len
    !config_ptr
    !s4
    !allowed
    !s3
    !enabled
    !s2
    !exports_len
    !exports_ptr
    !status_len
    !status_ptr
    return
L_ERR_STATUS:
    !has_status
    panic(103)
L_ERR_EXPORTS:
    !ok2
    panic(103)
L_ERR_ENABLED:
    !ok3
    panic(103)
L_ERR_ALLOWED:
    !ok4
    panic(103)
L_ERR_CONFIG:
    !ok5
    panic(103)
L_ERR_URL:
    !ok6
    panic(103)
L_ERR_FEATURES:
    !ok7
    panic(103)
