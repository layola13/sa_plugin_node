    const uname = std.posix.uname();
    const release = std.mem.sliceTo(&uname.release, 0);
    const owned = std.heap.page_allocator.dupe(u8, release) catch return 2;
    out_ptr.?.* = owned.ptr;
    out_len.?.* = owned.len;
    return 0;
