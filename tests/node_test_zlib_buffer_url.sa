    !v
    return
L_ERR:
    !ok
    !v
    !s
    panic(103)

@test "node.path join returns bytes"():
L_ENTRY:
    paths = stack_alloc 32
    store paths+0, S_SLASH_A as ptr
    store paths+8, 2 as u64
    store paths+16, S_SLASH_B as ptr
    store paths+24, 2 as u64
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_PATH_JOIN paths, 2, p, l, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ugt l, 0
    br has -> L_OK, L_LEN_ERR
L_OK:
    !has
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !has
    !p
    !l
    panic(103)

@test "node.path resolve returns bytes"():
L_ENTRY:
    paths = stack_alloc 32
    store paths+0, S_SLASH_A as ptr
    store paths+8, 2 as u64
    store paths+16, S_SLASH_B as ptr
    store paths+24, 2 as u64
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_PATH_RESOLVE paths, 2, p, l, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ugt l, 0
    br has -> L_OK, L_LEN_ERR
L_OK:
    !has
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !has
    !p
    !l
    panic(103)
