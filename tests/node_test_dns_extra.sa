@test "node.dns get_servers succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    EXPAND NODE_DNS_GET_SERVERS p, l
    pp = add 0, 0
    pl = add 0, 0
    ps = add 0, 0
    EXPAND NODE_DNS_PROMISES_GET_SERVERS pp, pl, ps
    promises_ok = eq ps, 0
    br promises_ok -> L_SET_PROMISES, L_ERR_PROMISES
L_SET_PROMISES:
    !promises_ok
    set_s = add 0, 0
    EXPAND NODE_DNS_PROMISES_SET_SERVERS set_s, pp, pl
    set_ok = eq set_s, 0
    br set_ok -> L_OK, L_ERR_SET
L_OK:
    !set_ok
    free_p = call @sa_node_plugin_free_buffer(p, l)
    free_pp = call @sa_node_plugin_free_buffer(pp, pl)
    !free_pp
    !free_p
    !set_s
    !ps
    !pl
    !pp
    !p
    !l
    return
L_ERR_PROMISES:
    !promises_ok
    panic(103)
L_ERR_SET:
    !set_ok
    panic(103)

@test "node.dns constants json succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_DNS_CONSTANTS_JSON p, l, s
    ok = eq s, 0
    br ok -> L_PROMISES, L_ERR
L_PROMISES:
    !ok
    pp = add 0, 0
    pl = add 0, 0
    ps = add 0, 0
    EXPAND NODE_DNS_PROMISES_CONSTANTS_JSON pp, pl, ps
    promises_ok = eq ps, 0
    br promises_ok -> L_OK, L_ERR_PROMISES
L_OK:
    !promises_ok
    has_len = ugt l, 0
    br has_len -> L_FREE, L_ERR_LEN
L_FREE:
    !has_len
    free_p = call @sa_node_plugin_free_buffer(p, l)
    free_pp = call @sa_node_plugin_free_buffer(pp, pl)
    !free_pp
    !free_p
    !ps
    !pl
    !pp
    !s
    !l
    !p
    return
L_ERR:
    !ok
    panic(103)
L_ERR_PROMISES:
    !promises_ok
    panic(103)
L_ERR_LEN:
    !has_len
    panic(103)

