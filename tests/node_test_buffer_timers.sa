// SA-native unit tests for Node buffer extras + timers + readline + punycode + querystring
@import "../node.sal"
@import "../node_extra.sal"

@const S_B64 = utf8:"aGVsbG8="
@const S_URL_OBJ = utf8:"blob:https://example.com/uuid"
@const S_UTF8 = utf8:"hello"
@const S_ENCODING = utf8:"utf8"

@test "node.buffer atob succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_BUFFER_ATOB S_B64, 8, p, l, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)

@test "node.buffer is_utf8 succeeds"():
L_ENTRY:
    v = add 0, 0
    EXPAND NODE_BUFFER_IS_UTF8 S_UTF8, 5, v
    !v
    return

@test "node.buffer resolve_object_url succeeds"():
L_ENTRY:
