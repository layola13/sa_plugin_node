// SA-native unit tests for Node events extras
@import "../node.sal"
@import "../node_extra.sal"

@const S_EVT = utf8:"test_event"
@const S_DATA = utf8:"data"

@test "node.events off succeeds"():
L_ENTRY:
    ee = add 0, 0
    EXPAND NODE_EVENTS_CREATE ee
    s = add 0, 0
    EXPAND NODE_EVENTS_OFF ee, S_EVT, 4, 0, s
    ok = eq s, 0
    br ok -> L_FREE, L_ERR
L_FREE:
    !ok
    !s
    EXPAND NODE_EVENTS_FREE ee, fs
    !fs
    return
L_ERR:
    !ok
    !s
    EXPAND NODE_EVENTS_FREE ee, fs2
    !fs2
    panic(103)

