    p_4 = add 0, 0
    EXPAND NODE_ZLIB_BROTLI_DECOMPRESS 0, 0, p_2, p_3, p_4
    ok = eq p_4, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !p_4
    !p_2
    !p_3
    return
L_ERR:
    !ok
    !p_2
    !p_3
    !p_4
    panic(103)

