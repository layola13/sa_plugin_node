// SA tests for more STATUS_JSON macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.web_crypto status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_WEB_CRYPTO_STATUS_JSON op, ol, s
    !s
    !ol
    !op
    return

