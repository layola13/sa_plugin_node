@test "node.process hrtime_bigint succeeds"():
L_ENTRY:
    EXPAND NODE_PROCESS_HRTIME_BIGINT v, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    positive = ugt v, 0
    br positive -> L_DONE, L_VALUE_ERR
L_DONE:
    !positive
    !v
    return
L_ERR:
    !ok
    !v
    !s
    panic(103)
L_VALUE_ERR:
    !positive
    !v
    panic(103)

