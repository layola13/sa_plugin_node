// SA tests for Node async_hooks: async_resource_snapshot_json
@import "../node.sal"
@import "../node_extra.sal"
@const S_TYPE = utf8:"test-res"

@test "node.async_hooks async_resource_snapshot_json"():
L_ENTRY:
    r = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_ASYNC_HOOKS_ASYNC_RESOURCE_CREATE S_TYPE, 9, 0, r
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_ASYNC_HOOKS_ASYNC_RESOURCE_SNAPSHOT_JSON r, op, ol
    EXPAND NODE_ASYNC_HOOKS_ASYNC_RESOURCE_FREE r
    !ol
    !op
    !s1
    !r
    return
