// SA-native unit tests for Node URL extras + Util extras
@import "../node.sal"

@const S_URL = utf8:"https://example.com/path?q=1"
@const S_MSG = utf8:"test msg"
@const S_JSON_A = utf8:"{\"a\":1}"
@const S_JSON_B = utf8:"{\"b\":2}"
@const S_MOD = utf8:"module"
@const S_CODE = utf8:"test"
@const S_X = utf8:"x"
@const S_NAME = utf8:"name"
@const S_HINT = utf8:"use old fn"
@const S_FILE = utf8:"test.js"
@const S_ENV_CONTENT = utf8:"FOO=bar\nBAR=baz\n"
@const S_FMT = utf8:"hello %s"
@const S_ARGS = utf8:"[\"world\"]"
@const S_FMT_OPTIONS = utf8:"{\"colors\":false}"
@const S_UTF8 = utf8:"utf-8"

@test "node.url new and free succeeds"():
L_ENTRY:
    u = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_URL_NEW S_URL, 28, u, s1
    ok = eq s1, 0
    br ok -> L_FREE, L_ERR
L_FREE:
    !ok
    !s1
    s2 = add 0, 0
    EXPAND NODE_URL_FREE u, s2
    !s2
    return
L_ERR:
    !ok
    !s1
    panic(103)

@test "node.url get_href succeeds"():
L_ENTRY:
    u = add 0, 0
    hp = add 0, 0
    hl = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_URL_NEW S_URL, 28, u, s1
    ok = eq s1, 0
    br ok -> L_GET, L_ERR
L_GET:
    !ok
    !s1
    EXPAND NODE_URL_GET_HREF u, hp, hl, s2
    ok2 = eq s2, 0
    br ok2 -> L_DONE, L_ERR2
L_DONE:
    !ok2
    !s2
    !hp
    !hl
    EXPAND NODE_URL_FREE u, s3
    !s3
    return
L_ERR:
    !ok
    !s1
    !hp
    !hl
    !s2
    !s3
    panic(103)
L_ERR2:
    !ok2
    !s2
    !hp
    !hl
    EXPAND NODE_URL_FREE u, s3
    !s3
    panic(103)

