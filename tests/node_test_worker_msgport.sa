// SA tests for Node worker_threads: message_port ops, environment_data
@import "../node.sal"
@import "../node_extra.sal"
@const S_KEY = utf8:"test"

@test "node.worker_threads message_port_close"():
L_ENTRY:
    ch1 = add 0, 0
    ch2 = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_WORKER_THREADS_MESSAGE_CHANNEL_NEW ch1, ch2, s1
    s2 = add 0, 0
    EXPAND NODE_WORKER_THREADS_MESSAGE_PORT_CLOSE ch1, s2
    s3 = add 0, 0
    EXPAND NODE_WORKER_THREADS_MESSAGE_PORT_FREE ch1, s3
    s4 = add 0, 0
    EXPAND NODE_WORKER_THREADS_MESSAGE_PORT_FREE ch2, s4
    !s4
    !s3
    !s2
    !s1
    !ch2
    !ch1
    return
