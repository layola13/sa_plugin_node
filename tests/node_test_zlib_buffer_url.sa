@test "node.url new and free succeeds"():
L_ENTRY:
    u = add 0, 0
    s = add 0, 0
    EXPAND NODE_URL_NEW S_URL, 28, u, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ne u, 0
    br has -> L_FREE, L_U_ERR
L_FREE:
    !has
    s2 = add 0, 0
    EXPAND NODE_URL_FREE u, s2
    !u
    return
L_ERR:
    !ok
    !u
    panic(103)
L_U_ERR:
    !has
    !u
    panic(103)

@test "node.url get_href returns bytes"():
L_ENTRY:
    u = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_URL_NEW S_URL, 28, u, s1
    ok1 = eq s1, 0
    br ok1 -> L_GET, L_ERR1
L_GET:
    !ok1
    !s1
    hp = add 0, 0
    hl = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_URL_GET_HREF u, hp, hl, s2
    ok2 = eq s2, 0
    br ok2 -> L_CHK, L_ERR2
L_CHK:
    !ok2
    !s2
    has = ugt hl, 0
    br has -> L_FREE, L_LEN_ERR
L_FREE:
    !has
    !hp
    !hl
    s3 = add 0, 0
    EXPAND NODE_URL_FREE u, s3
    !u
    return
L_ERR1:
    !ok1
    !u
    panic(103)
L_ERR2:
    !ok2
    !hp
    !hl
    !u
    panic(103)
L_LEN_ERR:
    !has
    !hp
    !hl
    !u
    panic(103)

