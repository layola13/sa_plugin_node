@test "smoke node console time stamp"():
L_ENTRY:
    p_2 = add 0, 0
    EXPAND NODE_CONSOLE_TIME_STAMP 0, 0, p_2
    ok = eq p_2, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !p_2
    return
L_ERR:
    !ok
    !p_2
    panic(103)

