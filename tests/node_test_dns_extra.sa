// SA-native unit tests for Node DNS extras
@import "../node.sal"
@import "../node_extra.sal"

@const S_HOST = utf8:"example.com"
@const S_LOCALHOST = utf8:"localhost"
@const S_IP = utf8:"127.0.0.1"
@const S_IPV4FIRST = utf8:"ipv4first"
@const S_VERBATIM = utf8:"verbatim"

@test "node.dns resolve4 succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_DNS_RESOLVE4 S_HOST, 11, p, l, s
    ok = eq s, 0
    br ok -> L_OK, L_CHK
L_OK:
    !ok
    !s
    !p
    !l
    return
L_CHK:
    !ok
    !s
    !p
    !l
    return

