// Tests for all STATUS_JSON shim macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.worker_threads worker_data returns bytes"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    EXPAND NODE_WORKER_THREADS_WORKER_DATA p, l
    has = ugt l, 0
    br has -> L_OK, L_ERR
L_OK:
    !has
    !p
    !l
    return
L_ERR:
    !has
    !p
    !l
    panic(103)

@test "node.worker_threads thread_name returns bytes"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    EXPAND NODE_WORKER_THREADS_THREAD_NAME p, l
    has = ugt l, 0
    br has -> L_OK, L_ERR
L_OK:
    !has
    !p
