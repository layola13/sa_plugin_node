// SA tests for more STATUS_JSON macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.iterable_streams status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_ITERABLE_STREAMS_STATUS_JSON op, ol, s
    !s
    !ol
    !op
    return

