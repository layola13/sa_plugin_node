// SA tests for Node cluster top-level facade helpers
@import "../node.sal"
@import "../node_extra.sal"
@const S_CLUSTER_TOP_JSON = utf8:"{\"exec\":\"/bin/cat\",\"cwd\":\".\",\"env\":{\"SA_CLUSTER_TOP\":\"1\"}}"

@test "node.cluster top level helpers"():
L_ENTRY:
    s0 = add 0, 0
    EXPAND NODE_CLUSTER_SETUP_PRIMARY_JSON S_CLUSTER_TOP_JSON, 58, s0
    ok0 = eq s0, 0
    br ok0 -> L_STATUS, L_ERR_SETUP
L_STATUS:
    !ok0
    status_ptr = add 0, 0
    status_len = add 0, 0
    EXPAND NODE_CLUSTER_STATUS_JSON status_ptr, status_len
    ok1 = ne status_ptr, 0
    br ok1 -> L_EXPORTS, L_ERR_STATUS
L_EXPORTS:
    !ok1
    exports_ptr = add 0, 0
    exports_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_CLUSTER_TOP_EXPORTS_JSON exports_ptr, exports_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_PRIMARY, L_ERR_EXPORTS
L_PRIMARY:
    !ok2
    primary_ptr = add 0, 0
    primary_len = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_CLUSTER_TOP_PRIMARY_CONFIG_JSON primary_ptr, primary_len, s3
    ok3 = eq s3, 0
    br ok3 -> L_FEATURES, L_ERR_PRIMARY
L_FEATURES:
    !ok3
    feature_ptr = add 0, 0
    feature_len = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_CLUSTER_TOP_FEATURE_SUPPORT_JSON feature_ptr, feature_len, s4
    ok4 = eq s4, 0
    br ok4 -> L_FREE, L_ERR_FEATURES
L_FREE:
    !ok4
    free_feature = call @sa_node_plugin_free_buffer(feature_ptr, feature_len)
    free_primary = call @sa_node_plugin_free_buffer(primary_ptr, primary_len)
    free_exports = call @sa_node_plugin_free_buffer(exports_ptr, exports_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_exports
    !free_primary
    !free_feature
    !s4
    !feature_len
    !feature_ptr
    !s3
    !primary_len
    !primary_ptr
    !s2
    !exports_len
    !exports_ptr
    !s0
    !status_len
    !status_ptr
    return
L_ERR_SETUP:
    !ok0
    panic(103)
L_ERR_STATUS:
    !ok1
    panic(103)
L_ERR_EXPORTS:
    !ok2
    panic(103)
L_ERR_PRIMARY:
    !ok3
    panic(103)
L_ERR_FEATURES:
    !ok4
    panic(103)
