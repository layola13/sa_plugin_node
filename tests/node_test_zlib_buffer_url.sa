    !s2
    !gp
    !gl
    !up
    !ul
    panic(103)
L_LEN_ERR:
    !len_ok
    !up
    !ul
    panic(103)

@test "node.zlib deflate_raw succeeds"():
L_ENTRY:
    dp = add 0, 0
    dl = add 0, 0
    s = add 0, 0
    EXPAND NODE_ZLIB_DEFLATE_RAW dp, dl, s, S_DATA, 11
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ugt dl, 0
    br has -> L_OK, L_LEN_ERR
L_OK:
    !has
    !dp
    !dl
    return
L_ERR:
    !ok
    !dp
    !dl
    !s
    panic(103)
L_LEN_ERR:
    !has
    !dp
    !dl
    panic(103)

