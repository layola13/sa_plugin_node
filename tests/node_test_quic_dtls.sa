// SA smoke tests for QUIC / HTTP3 / DTLS native endpoint subsets
@import "../node.sal"

@const S_LOOP4 = utf8:"127.0.0.1"
@const S_H3 = utf8:"h3"
@const S_CUBIC = utf8:"cubic"
@const S_RENO = utf8:"reno"
@const S_AUTH = utf8:"example.test"
@const S_PATH = utf8:"/echo"
@const S_POST = utf8:"POST"
@const S_H3_MSG = utf8:"ping"
@const S_DTLS_MSG = utf8:"hi"

@test "node.quic http3 dtls smoke"():
L_ENTRY:
    endpoint = add 0, 0
    s_listen = add 0, 0
    EXPAND NODE_QUIC_LISTEN endpoint, s_listen, 4, S_LOOP4, 9, 18782, S_H3, 2, S_CUBIC, 5, 1500
    snap_ptr = add 0, 0
    snap_len = add 0, 0
    s_snap = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_SNAPSHOT_JSON snap_ptr, snap_len, s_snap, endpoint
    qaddr_ptr = add 0, 0
    qaddr_len = add 0, 0
    s_qaddr = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_ADDRESS_JSON qaddr_ptr, qaddr_len, s_qaddr, endpoint
    qaddr_ok = eq s_qaddr, 0
    br qaddr_ok -> L_QUIC_ADDR_LEN, L_ERR_QUIC_ADDR
L_QUIC_ADDR_LEN:
    !qaddr_ok
    qaddr_has_len = ugt qaddr_len, 0
    br qaddr_has_len -> L_HAS_REF, L_ERR_QUIC_ADDR_LEN
L_HAS_REF:
    !qaddr_has_len
    has_ref = add 0, 0
    s_has_ref = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_HAS_REF s_has_ref, has_ref, endpoint
    client_endpoint = add 0, 0
    s_client_connect = add 0, 0
    EXPAND NODE_QUIC_CONNECT client_endpoint, s_client_connect, 4, S_LOOP4, 9, 18782, 0, 0, 0, S_H3, 2, S_RENO, 4, 500
    client_remote_ptr = add 0, 0
    client_remote_len = add 0, 0
    s_client_remote = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_REMOTE_ADDRESS_JSON client_remote_ptr, client_remote_len, s_client_remote, client_endpoint
    session = add 0, 0
    s_session = add 0, 0
    EXPAND NODE_HTTP3_CREATE_SESSION session, s_session, endpoint, S_AUTH, 12, S_PATH, 5, S_POST, 4
    client_session = add 0, 0
    s_client_session = add 0, 0
    EXPAND NODE_HTTP3_CREATE_SESSION client_session, s_client_session, client_endpoint, S_AUTH, 12, S_PATH, 5, S_POST, 4
    h3_ptr = add 0, 0
    h3_len = add 0, 0
    s_h3 = add 0, 0
    EXPAND NODE_HTTP3_SESSION_SNAPSHOT_JSON h3_ptr, h3_len, s_h3, session
    s_h3_send = add 0, 0
    EXPAND NODE_HTTP3_SESSION_SEND_DATAGRAM s_h3_send, client_session, S_H3_MSG, 4
    h3_recv_ptr = add 0, 0
    h3_recv_len = add 0, 0
    h3_recv_host_ptr = add 0, 0
    h3_recv_host_len = add 0, 0
    h3_recv_port = add 0, 0
    s_h3_recv = add 0, 0
    EXPAND NODE_HTTP3_SESSION_RECV_DATAGRAM h3_recv_ptr, h3_recv_len, h3_recv_host_ptr, h3_recv_host_len, h3_recv_port, s_h3_recv, session, 64
    dtls_status_ptr = add 0, 0
    dtls_status_len = add 0, 0
    EXPAND NODE_DTLS_STATUS_JSON dtls_status_ptr, dtls_status_len
    dtls_server = add 0, 0
    s_dtls_listen = add 0, 0
    EXPAND NODE_DTLS_LISTEN dtls_server, s_dtls_listen, 4, S_LOOP4, 9, 18783
    dtls_listen_ok = eq s_dtls_listen, 0
    br dtls_listen_ok -> L_DTLS_SNAPSHOT, L_ERR_DTLS_LISTEN
L_DTLS_SNAPSHOT:
    !dtls_listen_ok
    dsnap_ptr = add 0, 0
    dsnap_len = add 0, 0
    s_dsnap = add 0, 0
    EXPAND NODE_DTLS_ENDPOINT_SNAPSHOT_JSON dsnap_ptr, dsnap_len, s_dsnap, dtls_server
    daddr_ptr = add 0, 0
    daddr_len = add 0, 0
    s_daddr = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_ADDRESS_JSON daddr_ptr, daddr_len, s_daddr, dtls_server
    dsnap_ok = eq s_dsnap, 0
    br dsnap_ok -> L_DTLS_ADDR, L_ERR_DTLS_SNAPSHOT
L_DTLS_ADDR:
    !dsnap_ok
    daddr_ok = eq s_daddr, 0
    br daddr_ok -> L_DTLS_ADDR_LEN, L_ERR_DTLS_ADDR
L_DTLS_ADDR_LEN:
    !daddr_ok
    daddr_has_len = ugt daddr_len, 0
    br daddr_has_len -> L_DTLS_SNAPSHOT_LEN, L_ERR_DTLS_ADDR_LEN
L_DTLS_SNAPSHOT_LEN:
    !daddr_has_len
    dsnap_has_len = ugt dsnap_len, 0
    br dsnap_has_len -> L_DTLS_CONNECT, L_ERR_DTLS_SNAPSHOT_LEN
L_DTLS_CONNECT:
    !dsnap_has_len
    dtls_client = add 0, 0
    s_dtls_connect = add 0, 0
    EXPAND NODE_DTLS_CONNECT dtls_client, s_dtls_connect, 4, S_LOOP4, 9, 18783, 0, 0, 0
    dtls_connect_ok = eq s_dtls_connect, 0
    br dtls_connect_ok -> L_DTLS_SEND, L_ERR_DTLS_CONNECT
L_DTLS_SEND:
    !dtls_connect_ok
    s_dtls_send = add 0, 0
    EXPAND NODE_DTLS_SEND s_dtls_send, dtls_client, S_DTLS_MSG, 2
    dtls_send_ok = eq s_dtls_send, 0
    br dtls_send_ok -> L_DTLS_RECV, L_ERR_DTLS_SEND
L_DTLS_RECV:
    !dtls_send_ok
    dtls_recv_ptr = add 0, 0
    dtls_recv_len = add 0, 0
    dtls_recv_host_ptr = add 0, 0
    dtls_recv_host_len = add 0, 0
    dtls_recv_port = add 0, 0
    s_dtls_recv = add 0, 0
    EXPAND NODE_DTLS_RECV dtls_recv_ptr, dtls_recv_len, dtls_recv_host_ptr, dtls_recv_host_len, dtls_recv_port, s_dtls_recv, dtls_server, 64
    dtls_recv_ok = eq s_dtls_recv, 0
    br dtls_recv_ok -> L_CLOSE_DTLS, L_ERR_DTLS_RECV
L_CLOSE_DTLS:
    !dtls_recv_ok
    s_dtls_client_close = add 0, 0
    EXPAND NODE_DTLS_CLOSE s_dtls_client_close, dtls_client
    s_dtls_close = add 0, 0
    EXPAND NODE_DTLS_CLOSE s_dtls_close, dtls_server
    dtls_close_ok = eq s_dtls_close, 0
    br dtls_close_ok -> L_CLOSE_HTTP3, L_ERR_DTLS_CLOSE
L_CLOSE_HTTP3:
    !dtls_close_ok
    s_session_close = add 0, 0
    EXPAND NODE_HTTP3_SESSION_CLOSE s_session_close, session
    s_client_session_close = add 0, 0
    EXPAND NODE_HTTP3_SESSION_CLOSE s_client_session_close, client_session
    s_client_quic_close = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_CLOSE s_client_quic_close, client_endpoint
    s_quic_close = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_CLOSE s_quic_close, endpoint
    free_dtls_recv_host = call @sa_node_plugin_free_buffer(dtls_recv_host_ptr, dtls_recv_host_len)
    free_dtls_recv = call @sa_node_plugin_free_buffer(dtls_recv_ptr, dtls_recv_len)
    free_dsnap = call @sa_node_plugin_free_buffer(dsnap_ptr, dsnap_len)
    free_dtls_status = call @sa_node_plugin_free_buffer(dtls_status_ptr, dtls_status_len)
    free_daddr = call @sa_node_plugin_free_buffer(daddr_ptr, daddr_len)
    free_h3_recv_host = call @sa_node_plugin_free_buffer(h3_recv_host_ptr, h3_recv_host_len)
    free_h3_recv = call @sa_node_plugin_free_buffer(h3_recv_ptr, h3_recv_len)
    free_h3 = call @sa_node_plugin_free_buffer(h3_ptr, h3_len)
    free_client_remote = call @sa_node_plugin_free_buffer(client_remote_ptr, client_remote_len)
    free_qaddr = call @sa_node_plugin_free_buffer(qaddr_ptr, qaddr_len)
    free_snap = call @sa_node_plugin_free_buffer(snap_ptr, snap_len)
    s_dtls_client_free = add 0, 0
    EXPAND NODE_DTLS_FREE s_dtls_client_free, dtls_client
    s_dtls_free = add 0, 0
    EXPAND NODE_DTLS_FREE s_dtls_free, dtls_server
    s_client_session_free = add 0, 0
    EXPAND NODE_HTTP3_SESSION_FREE s_client_session_free, client_session
    s_session_free = add 0, 0
    EXPAND NODE_HTTP3_SESSION_FREE s_session_free, session
    s_client_quic_free = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_FREE s_client_quic_free, client_endpoint
    s_quic_free = add 0, 0
    EXPAND NODE_QUIC_ENDPOINT_FREE s_quic_free, endpoint
    !s_quic_free
    !s_client_quic_free
    !s_session_free
    !s_client_session_free
    !s_dtls_free
    !s_dtls_client_free
    !free_snap
    !free_qaddr
    !free_client_remote
    !free_h3
    !free_h3_recv
    !free_h3_recv_host
    !free_daddr
    !free_dtls_status
    !free_dsnap
    !free_dtls_recv
    !free_dtls_recv_host
    !dtls_recv_port
    !dtls_recv_host_len
    !dtls_recv_host_ptr
    !dtls_recv_len
    !dtls_recv_ptr
    !snap_len
    !snap_ptr
    !h3_recv_port
    !h3_recv_host_len
    !h3_recv_host_ptr
    !h3_recv_len
    !h3_recv_ptr
    !h3_len
    !h3_ptr
    !dsnap_len
    !dsnap_ptr
    !daddr_len
    !daddr_ptr
    !s_dtls_client_close
    !s_quic_close
    !s_client_quic_close
    !s_client_session_close
    !s_session_close
    !s_dtls_close
    !s_dtls_recv
    !s_dtls_send
    !s_dtls_connect
    !s_dsnap
    !s_dtls_listen
    !s_daddr
    !dtls_status_len
    !dtls_status_ptr
    !s_h3_recv
    !s_h3_send
    !s_h3
    !s_client_session
    !s_session
    !client_remote_len
    !client_remote_ptr
    !s_client_remote
    !s_client_connect
    !has_ref
    !s_has_ref
    !s_snap
    !s_qaddr
    !s_listen
    !dtls_client
    !dtls_server
    !client_session
    !session
    !client_endpoint
    !endpoint
    return
L_ERR_DTLS_LISTEN:
    !dtls_listen_ok
    !s_dtls_listen
    panic(103)
L_ERR_DTLS_SNAPSHOT:
    !dsnap_ok
    !s_dsnap
    panic(103)
L_ERR_DTLS_SNAPSHOT_LEN:
    !dsnap_has_len
    !dsnap_len
    !dsnap_ptr
    panic(103)
L_ERR_QUIC_ADDR:
    !qaddr_ok
    !s_qaddr
    panic(103)
L_ERR_QUIC_ADDR_LEN:
    !qaddr_has_len
    !qaddr_len
    !qaddr_ptr
    panic(103)
L_ERR_DTLS_ADDR:
    !daddr_ok
    !s_daddr
    panic(103)
L_ERR_DTLS_ADDR_LEN:
    !daddr_has_len
    !daddr_len
    !daddr_ptr
    panic(103)
L_ERR_DTLS_CLOSE:
    !dtls_close_ok
    !s_dtls_close
    panic(103)
L_ERR_DTLS_CONNECT:
    !dtls_connect_ok
    !s_dtls_connect
    panic(103)
L_ERR_DTLS_SEND:
    !dtls_send_ok
    !s_dtls_send
    panic(103)
L_ERR_DTLS_RECV:
    !dtls_recv_ok
    !s_dtls_recv
    panic(103)
