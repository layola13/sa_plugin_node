// SA tests for Node process top-level facade helpers
@import "../node.sal"
@import "../node_extra.sal"

@const S_INSPECT = utf8:"inspect=127.0.0.1:9229"
@const S_WARN = utf8:"careful"
@const S_WARN_TYPE = utf8:"DeprecationWarning"
@const S_WARN_CODE = utf8:"DEP9999"
@const S_WARN_DETAIL = utf8:"extra detail"

@test "node.process top level facade helpers"():
L_ENTRY:
    status_ptr = add 0, 0
    status_len = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_PROCESS_STATUS_JSON status_ptr, status_len, s1
    ok1 = eq s1, 0
    br ok1 -> L_EXPORTS, L_ERR_STATUS
L_EXPORTS:
    !ok1
    exports_ptr = add 0, 0
    exports_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_PROCESS_TOP_EXPORTS_JSON exports_ptr, exports_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_CONFIG, L_ERR_EXPORTS
L_CONFIG:
    !ok2
    config_ptr = add 0, 0
    config_len = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_PROCESS_TOP_CONFIG_JSON config_ptr, config_len, s3
    ok3 = eq s3, 0
    br ok3 -> L_FEATURES, L_ERR_CONFIG
L_FEATURES:
    !ok3
    feature_ptr = add 0, 0
    feature_len = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_PROCESS_TOP_FEATURE_SUPPORT_JSON feature_ptr, feature_len, s4
    ok4 = eq s4, 0
    br ok4 -> L_EXEC_PATH, L_ERR_FEATURES
L_EXEC_PATH:
    !ok4
    exec_path_ptr = add 0, 0
    exec_path_len = add 0, 0
    s5 = add 0, 0
    EXPAND NODE_PROCESS_EXEC_PATH exec_path_ptr, exec_path_len, s5
    ok5 = eq s5, 0
    br ok5 -> L_EXEC_PATH_LEN, L_ERR_EXEC_PATH
L_EXEC_PATH_LEN:
    !ok5
    ok6 = gt exec_path_len, 0
    br ok6 -> L_ARGV0, L_ERR_EXEC_PATH_LEN
L_ARGV0:
    !ok6
    argv0_ptr = add 0, 0
    argv0_len = add 0, 0
    s6 = add 0, 0
    EXPAND NODE_PROCESS_ARGV0 argv0_ptr, argv0_len, s6
    ok7 = eq s6, 0
    br ok7 -> L_ARGV0_LEN, L_ERR_ARGV0
L_ARGV0_LEN:
    !ok7
    ok8 = gt argv0_len, 0
    br ok8 -> L_EXEC_ARGV, L_ERR_ARGV0_LEN
L_EXEC_ARGV:
    !ok8
    exec_argv_ptr = add 0, 0
    exec_argv_len = add 0, 0
    s7 = add 0, 0
    EXPAND NODE_PROCESS_EXEC_ARGV_JSON exec_argv_ptr, exec_argv_len, s7
    ok9 = eq s7, 0
    br ok9 -> L_EXEC_ARGV_LEN, L_ERR_EXEC_ARGV
L_EXEC_ARGV_LEN:
    !ok9
    ok10 = gt exec_argv_len, 0
    br ok10 -> L_ALLOWED_FLAGS, L_ERR_EXEC_ARGV_LEN
L_ALLOWED_FLAGS:
    !ok10
    allowed_ptr = add 0, 0
    allowed_len = add 0, 0
    s8 = add 0, 0
    EXPAND NODE_PROCESS_ALLOWED_NODE_ENVIRONMENT_FLAGS_JSON allowed_ptr, allowed_len, s8
    ok11 = eq s8, 0
    br ok11 -> L_ALLOWED_FLAGS_LEN, L_ERR_ALLOWED_FLAGS
L_ALLOWED_FLAGS_LEN:
    !ok11
    ok12 = gt allowed_len, 0
    br ok12 -> L_ALLOWED_HAS, L_ERR_ALLOWED_FLAGS_LEN
L_ALLOWED_HAS:
    !ok12
    allowed_has = add 0, 0
    s9 = add 0, 0
    EXPAND NODE_PROCESS_ALLOWED_NODE_ENVIRONMENT_FLAGS_HAS allowed_has, s9, S_INSPECT, 22
    ok13 = eq s9, 0
    br ok13 -> L_ALLOWED_VALUE, L_ERR_ALLOWED_HAS
L_ALLOWED_VALUE:
    !ok13
    ok14 = eq allowed_has, 1
    br ok14 -> L_EMIT_WARNING, L_ERR_ALLOWED_VALUE
L_EMIT_WARNING:
    !ok14
    warning_ptr = add 0, 0
    warning_len = add 0, 0
    s10 = add 0, 0
    EXPAND NODE_PROCESS_EMIT_WARNING_JSON warning_ptr, warning_len, s10, S_WARN, 7, S_WARN_TYPE, 18, S_WARN_CODE, 7, S_WARN_DETAIL, 12
    ok15 = eq s10, 0
    br ok15 -> L_WARNING_LEN, L_ERR_EMIT_WARNING
L_WARNING_LEN:
    !ok15
    ok16 = gt warning_len, 0
    br ok16 -> L_FREE, L_ERR_WARNING_LEN
L_FREE:
    !ok16
    !s10
    free_warning = call @sa_node_plugin_free_buffer(warning_ptr, warning_len)
    !s9
    !allowed_has
    free_allowed = call @sa_node_plugin_free_buffer(allowed_ptr, allowed_len)
    free_exec_argv = call @sa_node_plugin_free_buffer(exec_argv_ptr, exec_argv_len)
    free_argv0 = call @sa_node_plugin_free_buffer(argv0_ptr, argv0_len)
    free_exec_path = call @sa_node_plugin_free_buffer(exec_path_ptr, exec_path_len)
    free_feature = call @sa_node_plugin_free_buffer(feature_ptr, feature_len)
    free_config = call @sa_node_plugin_free_buffer(config_ptr, config_len)
    free_exports = call @sa_node_plugin_free_buffer(exports_ptr, exports_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_exports
    !free_config
    !free_feature
    !free_exec_path
    !free_argv0
    !free_exec_argv
    !free_warning
    !free_allowed
    !warning_len
    !warning_ptr
    !s8
    !allowed_len
    !allowed_ptr
    !s7
    !exec_argv_len
    !exec_argv_ptr
    !s6
    !argv0_len
    !argv0_ptr
    !s5
    !exec_path_len
    !exec_path_ptr
    !s4
    !feature_len
    !feature_ptr
    !s3
    !config_len
    !config_ptr
    !s2
    !exports_len
    !exports_ptr
    !s1
    !status_len
    !status_ptr
    return
L_ERR_STATUS:
    !ok1
    panic(103)
L_ERR_EXPORTS:
    !ok2
    panic(103)
L_ERR_CONFIG:
    !ok3
    panic(103)
L_ERR_FEATURES:
    !ok4
    panic(103)
L_ERR_EXEC_PATH:
    !ok5
    panic(105)
L_ERR_EXEC_PATH_LEN:
    !ok6
    panic(106)
L_ERR_ARGV0:
    !ok7
    panic(107)
L_ERR_ARGV0_LEN:
    !ok8
    panic(108)
L_ERR_EXEC_ARGV:
    !ok9
    panic(109)
L_ERR_EXEC_ARGV_LEN:
    !ok10
    panic(110)
L_ERR_ALLOWED_FLAGS:
    !ok11
    panic(111)
L_ERR_ALLOWED_FLAGS_LEN:
    !ok12
    panic(112)
L_ERR_ALLOWED_HAS:
    !ok13
    panic(113)
L_ERR_ALLOWED_VALUE:
    !ok14
    panic(114)
L_ERR_EMIT_WARNING:
    !ok15
    panic(115)
L_ERR_WARNING_LEN:
    !ok16
    panic(116)

@test "node.process credential helpers"():
L_ENTRY:
    euid = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_PROCESS_GETEUID euid, s1
    ok1 = eq s1, 0
    br ok1 -> L_GETEGID, L_ERR_GETEUID
L_GETEGID:
    !ok1
    egid = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_PROCESS_GETEGID egid, s2
    ok2 = eq s2, 0
    br ok2 -> L_GROUPS, L_ERR_GETEGID
L_GROUPS:
    !ok2
    groups_ptr = add 0, 0
    groups_len = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_PROCESS_GROUPS groups_ptr, groups_len, s3
    ok3 = eq s3, 0
    br ok3 -> L_GROUPS_LEN, L_ERR_GROUPS
L_GROUPS_LEN:
    !ok3
    ok4 = gt groups_len, 1
    br ok4 -> L_FREE, L_ERR_GROUPS_LEN
L_FREE:
    !ok4
    free_groups = call @sa_node_plugin_free_buffer(groups_ptr, groups_len)
    !free_groups
    !s3
    !groups_len
    !groups_ptr
    !s2
    !egid
    !s1
    !euid
    return
L_ERR_GETEUID:
    !ok1
    panic(117)
L_ERR_GETEGID:
    !ok2
    panic(118)
L_ERR_GROUPS:
    !ok3
    panic(119)
L_ERR_GROUPS_LEN:
    !ok4
    panic(120)

@test "node.process cpu_usage top level bytes"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_PROCESS_CPU_USAGE p, l, s
    ok = eq s, 0
    br ok -> L_LEN, L_ERR
L_LEN:
    !ok
    non_empty = gt l, 0
    br non_empty -> L_OK, L_ERR_LEN
L_OK:
    !non_empty
    !s
    !l
    !p
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(121)
L_ERR_LEN:
    !non_empty
    !p
    !l
    !s
    panic(122)
