// Tests for OS and Process macros not yet covered.
@import "../node.sal"
@import "../node_extra.sal"

@test "node.os tmpdir returns bytes"():
L_ENTRY:
    EXPAND NODE_OS_TMPDIR p, l, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    non_empty = ugt l, 0
    br non_empty -> L_DONE, L_LEN_ERR
L_DONE:
    !non_empty
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !non_empty
    !p
    !l
    panic(103)

