@test "node.util text_encoder encode succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_UTIL_TEXT_ENCODER_ENCODE S_MSG, 8, p, l, s
    ok = eq s, 0
    br ok -> L_LEN, L_ERR
L_LEN:
    !ok
    ok_len = eq l, 8
    br ok_len -> L_OK, L_LEN_ERR
L_OK:
    !ok_len
    free_enc = call @sa_node_plugin_free_buffer(p, l)
    !free_enc
    !s
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !ok_len
    !p
    !l
    !s
    panic(104)

