// SA tests for Node test_runner native config helpers
@import "../node.sal"
@import "../node_extra.sal"

@const S_REPORTER = utf8:"spec"

@test "node.test_runner native helpers"():
L_ENTRY:
    status_ptr = add 0, 0
    status_len = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_TEST_RUNNER_STATUS_JSON status_ptr, status_len, s1
    ok1 = eq s1, 0
    br ok1 -> L_REPORTERS, L_ERR_STATUS
L_REPORTERS:
    !ok1
    reporters_ptr = add 0, 0
    reporters_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_TEST_RUNNER_BUILTIN_REPORTERS_JSON reporters_ptr, reporters_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_HAS, L_ERR_REPORTERS
L_HAS:
    !ok2
    has_spec = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_TEST_RUNNER_HAS_BUILTIN_REPORTER has_spec, s3, S_REPORTER, 4
    ok3 = eq s3, 0
    hit3 = eq has_spec, 1
    both3 = and ok3, hit3
    br both3 -> L_CONFIG, L_ERR_HAS
L_CONFIG:
    !both3
    config_ptr = add 0, 0
    config_len = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_TEST_RUNNER_CONFIG_JSON config_ptr, config_len, s4
    ok4 = eq s4, 0
    br ok4 -> L_FREE, L_ERR_CONFIG
L_FREE:
    !ok4
    free_config = call @sa_node_plugin_free_buffer(config_ptr, config_len)
    free_reporters = call @sa_node_plugin_free_buffer(reporters_ptr, reporters_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_reporters
    !free_config
    !s4
    !config_len
    !config_ptr
    !s3
    !has_spec
    !s2
    !reporters_len
    !reporters_ptr
    !s1
    !status_len
    !status_ptr
    return
L_ERR_STATUS:
    !ok1
    panic(103)
L_ERR_REPORTERS:
    !ok2
    panic(103)
L_ERR_HAS:
    !both3
    panic(103)
L_ERR_CONFIG:
    !ok4
    panic(103)
