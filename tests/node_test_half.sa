// Console
// ============================================================

@test "console.log"():
    EXPAND NODE_CONSOLE_LOG s, S_LOG 7
    !s
    return

@test "console.warn"():
    EXPAND NODE_CONSOLE_WARN S_WARN4 4
    return

@test "console.error"():
    EXPAND NODE_CONSOLE_ERROR s, S_ERR5 5
    !s
    return

@test "console.info"():
    EXPAND NODE_CONSOLE_INFO S_INF 4
    return

@test "console.debug"():
    EXPAND NODE_CONSOLE_DEBUG S_DBG 5
    return

@test "console.clear"():
    EXPAND NODE_CONSOLE_CLEAR s
    !s
    return

@test "console.dir"():
    EXPAND NODE_CONSOLE_DIR S_DIR 3
    return

@test "console.trace"():
    EXPAND NODE_CONSOLE_TRACE S_TRC 5
    return

@test "console.table"():
    EXPAND NODE_CONSOLE_TABLE S_TBL 2
    return

@test "console.assert"():
    EXPAND NODE_CONSOLE_ASSERT 1, S_LOG, 7
    return

@test "console.time and timeEnd"():
    EXPAND NODE_CONSOLE_TIME s1, S_LBL 4
    !s1
    EXPAND NODE_TIMERS_SLEEP ss, 10
    EXPAND NODE_CONSOLE_TIME_END s2, v, S_LBL 4
    !s2
    !ss
    !v
    return

@test "console.group and groupEnd"():
    EXPAND NODE_CONSOLE_GROUP
    EXPAND NODE_CONSOLE_GROUP_END
    return

