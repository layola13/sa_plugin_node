// SA tests for Node trace_events: get_enabled_categories
@import "../node.sal"
@import "../node_extra.sal"
@const S_CAT = utf8:"test-cat"

@test "node.trace_events get_enabled_categories"():
L_ENTRY:
    t = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_TRACE_EVENTS_CREATE_TRACING S_CAT, 8, t
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_TRACE_EVENTS_GET_ENABLED_CATEGORIES t, op, ol
    EXPAND NODE_TRACE_EVENTS_TRACING_FREE t
    !ol
    !op
    !s1
    !t
    return
