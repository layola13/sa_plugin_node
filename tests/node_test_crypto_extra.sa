@test "node.crypto random_int returns valid"():
L_ENTRY:
    v = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_RANDOM_INT 0, 100, v, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    !v
    return
L_ERR:
    !ok
    !v
    panic(103)

@test "node.crypto random_fill succeeds"():
L_ENTRY:
    buf = stack_alloc 32
    s = add 0, 0
    EXPAND NODE_CRYPTO_RANDOM_FILL buf, 32, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    return
L_ERR:
    !ok
    !s
    panic(103)

@test "node.crypto get_hashes returns bytes"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    EXPAND NODE_CRYPTO_GET_HASHES p, l
    has_data = ugt l, 0
    br has_data -> L_OK, L_ERR
L_OK:
    !has_data
    !p
    !l
    return
L_ERR:
    !has_data
    !p
    !l
    panic(103)

@test "node.crypto generate_key succeeds"():
L_ENTRY:
    k = add 0, 0
    kl = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_GENERATE_KEY S_SHA256, 6, 256, k, kl, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ne k, 0
    br has -> L_OK, L_K_ERR
L_OK:
    !has
    !k
    !kl
    return
L_ERR:
    !ok
    !k
    !kl
    panic(103)
L_K_ERR:
    !has
    !k
    !kl
    panic(103)

@test "node.crypto hkdf succeeds"():
L_ENTRY:
    op = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_HKDF S_SHA256, 6, S_SECRET, 9, S_SECRET, 9, S_DATA, 5, 32, op, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ne op, 0
    br has -> L_OK, L_LEN_ERR
L_OK:
    !has
    !op
    return
L_ERR:
    !ok
    !op
    !s
    panic(103)
L_LEN_ERR:
    !has
    !op
    panic(103)

@test "node.crypto scrypt succeeds"():
L_ENTRY:
    op = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_SCRYPT S_SECRET, 9, S_SECRET, 9, 1024, 8, 1, 32, op, s
    ok = eq s, 0
    br ok -> L_CHK, L_ERR
L_CHK:
    !ok
    !s
    has = ne op, 0
    br has -> L_OK, L_LEN_ERR
L_OK:
    !has
    !op
    return
L_ERR:
    !ok
    !op
    !s
    panic(103)
L_LEN_ERR:
    !has
    !op
    panic(103)
