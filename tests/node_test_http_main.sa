// SA compile-surface test for Node HTTP/HTTPS helpers via the main node.sal facade
@import "../node.sal"

@const S_URL = utf8:"http://127.0.0.1:1/"
@const S_PATH = utf8:"/"
@const S_METHOD = utf8:"GET"
@const S_HEADER = utf8:"accept"
@const S_VALUE = utf8:"*/*"
@const S_HOST = utf8:"127.0.0.1"
@const S_TEXT = utf8:"text/plain"

@test "node.http main facade surface compiles"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    h1 = add 0, 0
    h2 = add 0, 0
    h3 = add 0, 0
    n = add 0, 0

    EXPAND NODE_HTTP_CLIENT_NEW 0, h1, s
    EXPAND NODE_HTTP_CLIENT_REQ_NEW h1, S_METHOD, 3, S_PATH, h2, s
    EXPAND NODE_HTTP_CLIENT_REQ_ADD_HEADER h2, S_HEADER, 6, S_VALUE, 3, s
    EXPAND NODE_HTTP_CLIENT_REQ_SET_BODY h2, 0, 0, s
    EXPAND NODE_HTTP_CLIENT_REQ_SEND h2, h3, s
    EXPAND NODE_HTTP_CLIENT_REQ_SEND_ASYNC h2, h3, s
    EXPAND NODE_HTTP_CLIENT_ASYNC_POLL h3, n, s
    EXPAND NODE_HTTP_CLIENT_ASYNC_TAKE_RESPONSE h3, h2, s
    EXPAND NODE_HTTP_CLIENT_ASYNC_FREE h3, s
    EXPAND NODE_HTTP_CLIENT_RESP_STATUS h2, s
    EXPAND NODE_HTTP_CLIENT_RESP_GET_HEADER h2, S_HEADER, 6, p, l, s
    EXPAND NODE_HTTP_CLIENT_RESP_BODY_SLICE h2, p, l, s
    EXPAND NODE_HTTP_CLIENT_RESP_BODY_READER h2, h3, s
    EXPAND NODE_HTTP_CLIENT_RESP_READ_CHUNK h3, p, 32, n, s
    EXPAND NODE_HTTP_CLIENT_BODY_READER_FREE h3, s
    EXPAND NODE_HTTP_CLIENT_RESP_FREE h2, s
    EXPAND NODE_HTTP_CLIENT_REQ_FREE h2, s
    EXPAND NODE_HTTP_CLIENT_FREE h1, s

    EXPAND NODE_HTTP_WEBSOCKET_CONNECT S_URL, 19, 0, h1, s
    EXPAND NODE_HTTP_WEBSOCKET_READ h1, 32, n, p, l, s
    EXPAND NODE_HTTP_WEBSOCKET_WRITE h1, 1, S_VALUE, 3, s
    EXPAND NODE_HTTP_WEBSOCKET_FREE h1, s

    EXPAND NODE_HTTP_SERVER_NEW h1, s
    EXPAND NODE_HTTP_SERVER_START h1, S_HOST, 9, 0, s
    EXPAND NODE_HTTP_SERVER_ACCEPT h1, h2, s
    EXPAND NODE_HTTP_SERVER_REQ_GET_METHOD h2, p, l, s
    EXPAND NODE_HTTP_SERVER_REQ_GET_PATH h2, p, l, s
    EXPAND NODE_HTTP_SERVER_REQ_GET_HEADER h2, S_HEADER, 6, p, l, s
    EXPAND NODE_HTTP_SERVER_REQ_GET_BODY h2, p, l, s
    EXPAND NODE_HTTP_SERVER_WEBSOCKET_UPGRADE h2, h3, s
    EXPAND NODE_HTTP_SERVER_WEBSOCKET_READ h3, 32, n, p, l, s
    EXPAND NODE_HTTP_SERVER_WEBSOCKET_WRITE h3, 1, S_VALUE, 3, s
    EXPAND NODE_HTTP_SERVER_WEBSOCKET_FREE h3, s
    EXPAND NODE_HTTP_SERVER_RESP_NEW h2, 200, h3, s
    EXPAND NODE_HTTP_SERVER_RESP_SET_CONTENT_TYPE h3, S_TEXT, 10, s
    EXPAND NODE_HTTP_SERVER_RESP_SEND h3, S_VALUE, 3, s
    EXPAND NODE_HTTP_SERVER_RESP_STREAM_NEW h2, 200, h3, s
    EXPAND NODE_HTTP_SERVER_RESP_STREAM_WRITE h3, S_VALUE, 3, s
    EXPAND NODE_HTTP_SERVER_RESP_STREAM_FLUSH h3, s
    EXPAND NODE_HTTP_SERVER_RESP_STREAM_END h3, s
    EXPAND NODE_HTTP_SERVER_RESP_STREAM_FREE h3, s
    EXPAND NODE_HTTP_SERVER_RESP_FREE h3, s
    EXPAND NODE_HTTP_SERVER_REQ_FREE h2, s
    EXPAND NODE_HTTP_SERVER_FREE h1, s

    !n
    !h3
    !h2
    !h1
    !s
    !l
    !p
    return
