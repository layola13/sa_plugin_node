@test "smoke node url free"():
L_ENTRY:
    p_1 = add 0, 0
    EXPAND NODE_URL_FREE 0, p_1
    ok = eq p_1, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !p_1
    return
L_ERR:
    !ok
    !p_1
    panic(103)

