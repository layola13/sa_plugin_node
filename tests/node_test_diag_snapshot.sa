// SA tests for Node diagnostics_channel: snapshot_json
@import "../node.sal"
@const S_CH = utf8:"snap-ch"

@test "node.diagnostics_channel snapshot_json"():
L_ENTRY:
    h = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_CREATE S_CH, 7, h, s1
    op = add 0, 0
    ol = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_SNAPSHOT_JSON h, op, ol, s2
    EXPAND NODE_DIAGNOSTICS_CHANNEL_FREE h
    !s2
    !ol
    !op
    !s1
    !h
    return
