// SA tests for more STATUS_JSON macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.repl status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_REPL_STATUS_JSON op, ol, s
    !s
    !ol
    !op
    return

