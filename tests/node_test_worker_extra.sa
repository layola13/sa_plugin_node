// SA tests for Node worker_threads extras: thread_name, worker_data
@import "../node.sal"

@test "node.worker_threads thread_name"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_WORKER_THREADS_THREAD_NAME op, ol, s
    !s
    !ol
    !op
    return

@test "node.worker_threads worker_data"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_WORKER_THREADS_WORKER_DATA op, ol
    !ol
    !op
    return
