@test "node.zlib unzip gzip succeeds"():
L_ENTRY:
    gp = add 0, 0
    gl = add 0, 0
    s1 = add 0, 0
    up = add 0, 0
    ul = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_ZLIB_GZIP gp, gl, s1, S_DATA, 11
    ok1 = eq s1, 0
    br ok1 -> L_UNZIP, L_ERR1
L_UNZIP:
    !ok1
    !s1
    EXPAND NODE_ZLIB_UNZIP up, ul, s2, gp, gl
    ok = eq s2, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s2
    !gp
    !gl
    !up
    !ul
    return
L_ERR1:
    !ok1
    !s1
    panic(103)
L_ERR:
    !ok
    !gp
    !gl
    !up
    !ul
    !s2
    panic(103)

