    EXPAND NODE_ZLIB_GZIP gp, gl, s1, S_DATA, 11
    ok1 = eq s1, 0
    br ok1 -> L_UNGZIP, L_ERR1
L_UNGZIP:
    !ok1
    !s1
    up = add 0, 0
    ul = add 0, 0
    s2 = add 0, 0
