// SA tests for Node stream: finished, compose
@import "../node.sal"
@import "../node_extra.sal"

@test "node.stream finished"():
L_ENTRY:
    p = add 0, 0
    s1 = add 0, 0
    op = add 0, 0
    ol = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_STREAM_PASSTHROUGH_NEW p
    EXPAND NODE_STREAM_FINISHED p, op, ol, s2
    !s2
    !ol
    !op
    !s1
    !p
    return
