// SA tests for Node stream: readable_destroy, writable_destroy
@import "../node.sal"

@test "node.stream readable_destroy"():
L_ENTRY:
    d = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_STREAM_DUPLEX_NEW d
    s2 = add 0, 0
    EXPAND NODE_STREAM_READABLE_DESTROY d, s2
    !s2
    !s1
    !d
    return

@test "node.stream writable_destroy"():
L_ENTRY:
    d = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_STREAM_DUPLEX_NEW d
    s2 = add 0, 0
    EXPAND NODE_STREAM_WRITABLE_DESTROY d, s2
    !s2
    !s1
    !d
    return
