@test "node.util inspect succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_UTIL_INSPECT p, l, s, S_JSON_A, 7
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    !p
    !l
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)

