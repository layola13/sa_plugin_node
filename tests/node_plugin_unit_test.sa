@test "node.console time time_end succeeds"():
L_ENTRY:
    EXPAND NODE_CONSOLE_TIME s1, S_LABEL, 13
    ok1 = eq s1, 0
    br ok1 -> L_TIME_OK, L_TIME_ERR
L_TIME_OK:
    !ok1
    !s1
    EXPAND NODE_CONSOLE_TIME_END s2, ms, S_LABEL, 13
    ok2 = eq s2, 0
    br ok2 -> L_OK, L_END_ERR
L_OK:
    !ok2
    !s2
    !ms
    return
L_TIME_ERR:
    !ok1
    !s1
    panic(103)
L_END_ERR:
    !ok2
    !s2
    !ms
    panic(103)

