@import "../node.sal"
@import "../node_extra.sal"
@test "smoke node punycode encode"():
L_ENTRY:
    out_ptr = add 0, 0
    out_len = add 0, 0
    out_status = add 0, 0
    EXPAND NODE_PUNYCODE_ENCODE out_ptr, out_len, out_status, S_DATA, 5
    ok = eq out_status, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !out_status
    !out_ptr
    !out_len
    return
L_ERR:
    !ok
    !out_ptr
    !out_len
    !out_status
    panic(103)
