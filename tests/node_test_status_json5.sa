// SA tests for more STATUS_JSON macros
@import "../node.sal"

@test "node.wasi status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_WASI_STATUS_JSON op, ol
    !ol
    !op
    return

