// SA tests for Node worker_threads extras
@import "../node.sal"

@test "node.worker_threads thread_id"():
L_ENTRY:
    v = add 0, 0
    EXPAND NODE_WORKER_THREADS_THREAD_ID v
    !v
    return

@test "node.worker_threads is_main_thread"():
L_ENTRY:
    v = add 0, 0
    EXPAND NODE_WORKER_THREADS_IS_MAIN_THREAD v
    !v
    return

@test "node.worker_threads is_internal_thread"():
L_ENTRY:
    v = add 0, 0
    s = add 0, 0
    EXPAND NODE_WORKER_THREADS_IS_INTERNAL_THREAD v, s
    !s
    !v
    return
