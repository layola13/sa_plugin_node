// SA tests for Node process top-level facade helpers
@import "../node.sal"
@import "../node_extra.sal"

@test "node.process top level facade helpers"():
L_ENTRY:
    status_ptr = add 0, 0
    status_len = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_PROCESS_STATUS_JSON status_ptr, status_len, s1
    ok1 = eq s1, 0
    br ok1 -> L_EXPORTS, L_ERR_STATUS
L_EXPORTS:
    !ok1
    exports_ptr = add 0, 0
    exports_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_PROCESS_TOP_EXPORTS_JSON exports_ptr, exports_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_CONFIG, L_ERR_EXPORTS
L_CONFIG:
    !ok2
    config_ptr = add 0, 0
    config_len = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_PROCESS_TOP_CONFIG_JSON config_ptr, config_len, s3
    ok3 = eq s3, 0
    br ok3 -> L_FEATURES, L_ERR_CONFIG
L_FEATURES:
    !ok3
    feature_ptr = add 0, 0
    feature_len = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_PROCESS_TOP_FEATURE_SUPPORT_JSON feature_ptr, feature_len, s4
    ok4 = eq s4, 0
    br ok4 -> L_EXEC_PATH, L_ERR_FEATURES
L_EXEC_PATH:
    !ok4
    exec_path_ptr = add 0, 0
    exec_path_len = add 0, 0
    s5 = add 0, 0
    EXPAND NODE_PROCESS_EXEC_PATH exec_path_ptr, exec_path_len, s5
    ok5 = eq s5, 0
    br ok5 -> L_EXEC_PATH_LEN, L_ERR_EXEC_PATH
L_EXEC_PATH_LEN:
    !ok5
    ok6 = gt exec_path_len, 0
    br ok6 -> L_ARGV0, L_ERR_EXEC_PATH_LEN
L_ARGV0:
    !ok6
    argv0_ptr = add 0, 0
    argv0_len = add 0, 0
    s6 = add 0, 0
    EXPAND NODE_PROCESS_ARGV0 argv0_ptr, argv0_len, s6
    ok7 = eq s6, 0
    br ok7 -> L_ARGV0_LEN, L_ERR_ARGV0
L_ARGV0_LEN:
    !ok7
    ok8 = gt argv0_len, 0
    br ok8 -> L_EXEC_ARGV, L_ERR_ARGV0_LEN
L_EXEC_ARGV:
    !ok8
    exec_argv_ptr = add 0, 0
    exec_argv_len = add 0, 0
    s7 = add 0, 0
    EXPAND NODE_PROCESS_EXEC_ARGV_JSON exec_argv_ptr, exec_argv_len, s7
    ok9 = eq s7, 0
    br ok9 -> L_EXEC_ARGV_LEN, L_ERR_EXEC_ARGV
L_EXEC_ARGV_LEN:
    !ok9
    ok10 = gt exec_argv_len, 0
    br ok10 -> L_FREE, L_ERR_EXEC_ARGV_LEN
L_FREE:
    !ok10
    free_exec_argv = call @sa_node_plugin_free_buffer(exec_argv_ptr, exec_argv_len)
    free_argv0 = call @sa_node_plugin_free_buffer(argv0_ptr, argv0_len)
    free_exec_path = call @sa_node_plugin_free_buffer(exec_path_ptr, exec_path_len)
    free_feature = call @sa_node_plugin_free_buffer(feature_ptr, feature_len)
    free_config = call @sa_node_plugin_free_buffer(config_ptr, config_len)
    free_exports = call @sa_node_plugin_free_buffer(exports_ptr, exports_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_exports
    !free_config
    !free_feature
    !free_exec_path
    !free_argv0
    !free_exec_argv
    !s7
    !exec_argv_len
    !exec_argv_ptr
    !s6
    !argv0_len
    !argv0_ptr
    !s5
    !exec_path_len
    !exec_path_ptr
    !s4
    !feature_len
    !feature_ptr
    !s3
    !config_len
    !config_ptr
    !s2
    !exports_len
    !exports_ptr
    !s1
    !status_len
    !status_ptr
    return
L_ERR_STATUS:
    !ok1
    panic(103)
L_ERR_EXPORTS:
    !ok2
    panic(103)
L_ERR_CONFIG:
    !ok3
    panic(103)
L_ERR_FEATURES:
    !ok4
    panic(103)
L_ERR_EXEC_PATH:
    !ok5
    panic(105)
L_ERR_EXEC_PATH_LEN:
    !ok6
    panic(106)
L_ERR_ARGV0:
    !ok7
    panic(107)
L_ERR_ARGV0_LEN:
    !ok8
    panic(108)
L_ERR_EXEC_ARGV:
    !ok9
    panic(109)
L_ERR_EXEC_ARGV_LEN:
    !ok10
    panic(110)
