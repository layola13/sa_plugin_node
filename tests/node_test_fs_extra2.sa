// SA tests for Node FS ops part 2: futimes, statfs, glob, mkdtemp, rm, truncate, etc.
@import "../node.sal"

@const S_TESTFILE = utf8:"/tmp/sa_node_test.txt"
@const S_TMPDIR = utf8:"/tmp"
@const S_GLOB = utf8:"/tmp/sa_node_*"
@const S_LNK = utf8:"/tmp/sa_node_link"
@const S_MT = utf8:"/tmp/tmpXXXXXX"

@test "node.fs futimes"():
L_ENTRY:
    fd = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_FS_OPEN S_TESTFILE, 24, 2, 0, fd, s1
    EXPAND NODE_FS_FUTIMES fd, 1000, 1000, s2
    EXPAND NODE_FS_CLOSE_FD fd, s3
    !s3
    !s2
    !s1
    !fd
    return

@test "node.fs statfs"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_FS_STATFS S_TMPDIR, p, l, s
    !s
    !p
    !l
    return

@test "node.fs glob"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_FS_GLOB S_GLOB, 18, p, l, s
    !s
    !p
    !l
    return

@test "node.fs mkdtemp"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_FS_MKDTEMP S_MT, 20, p, l, s
    !s
    !p
    !l
    return

@test "node.fs rm"():
L_ENTRY:
    s = add 0, 0
    EXPAND NODE_FS_RM S_TESTFILE, 24, 0, s
    !s
    return

@test "node.fs truncate"():
L_ENTRY:
    s = add 0, 0
    EXPAND NODE_FS_TRUNCATE S_TESTFILE, 24, 0, s
    !s
    return

@test "node.fs utimes"():
L_ENTRY:
    s = add 0, 0
    EXPAND NODE_FS_UTIMES S_TESTFILE, 24, 1000, 1000, s
    !s
    return

@test "node.fs link and rm"():
L_ENTRY:
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_FS_LINK S_TESTFILE, 24, S_LNK, 23, s1
    EXPAND NODE_FS_RM S_LNK, 23, 0, s2
    !s2
    !s1
    return

@test "node.fs symlink and rm"():
L_ENTRY:
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_FS_SYMLINK S_TESTFILE, 24, S_LNK, 23, s1
    EXPAND NODE_FS_RM S_LNK, 23, 1, s2
    !s2
    !s1
    return

@test "node.fs readv"():
L_ENTRY:
    fd = add 0, 0
    s1 = add 0, 0
    v = add 0, 0
    s2 = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_FS_OPEN S_TESTFILE, 24, 66, 438, fd, s1
    EXPAND NODE_FS_READV fd, 0, 0, v, s2
    EXPAND NODE_FS_CLOSE_FD fd, s3
    !s3
    !s2
    !v
    !s1
    !fd
    return

@test "node.fs writev"():
L_ENTRY:
    fd = add 0, 0
    s1 = add 0, 0
    v = add 0, 0
    s2 = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_FS_OPEN S_TESTFILE, 24, 66, 438, fd, s1
    EXPAND NODE_FS_WRITEV fd, 0, 0, v, s2
    EXPAND NODE_FS_CLOSE_FD fd, s3
    !s3
    !s2
    !v
    !s1
    !fd
    return
