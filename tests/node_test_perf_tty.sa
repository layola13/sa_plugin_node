// SA-native unit tests for Node perf hooks + TTY extras
@import "../node.sal"

@const S_MARK = utf8:"test_mark"
@const S_START = utf8:"start"
@const S_END = utf8:"end"
@const S_MEASURE = utf8:"test_measure"

@test "node.perf_hooks mark succeeds"():
L_ENTRY:
    s = add 0, 0
    EXPAND NODE_PERF_HOOKS_MARK S_MARK, 9, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    return
L_ERR:
    !ok
    !s
    panic(103)

@test "node.perf_hooks measure succeeds"():
L_ENTRY:
    s = add 0, 0
    s2 = add 0, 0
    v = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_PERF_HOOKS_MARK S_START, 5, s
    EXPAND NODE_PERF_HOOKS_MARK S_END, 3, s2
    EXPAND NODE_PERF_HOOKS_MEASURE S_MEASURE, 12, S_START, 5, S_END, 3, v, s3
    !s3
    !s2
    !s
    !v
    return

