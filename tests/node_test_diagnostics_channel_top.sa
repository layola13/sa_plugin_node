// SA tests for Node diagnostics_channel top-level facade helpers
@import "../node.sal"
@import "../node_extra.sal"

@test "node.diagnostics_channel top level helpers"():
L_ENTRY:
    status_ptr = add 0, 0
    status_len = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_TOP_STATUS_JSON status_ptr, status_len, s1
    ok1 = eq s1, 0
    br ok1 -> L_EXPORTS, L_ERR_STATUS
L_EXPORTS:
    !ok1
    exports_ptr = add 0, 0
    exports_len = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_TOP_EXPORTS_JSON exports_ptr, exports_len, s2
    ok2 = eq s2, 0
    br ok2 -> L_FACTORIES, L_ERR_EXPORTS
L_FACTORIES:
    !ok2
    factories_ptr = add 0, 0
    factories_len = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_TOP_FACTORIES_JSON factories_ptr, factories_len, s3
    ok3 = eq s3, 0
    br ok3 -> L_FEATURES, L_ERR_FACTORIES
L_FEATURES:
    !ok3
    feature_ptr = add 0, 0
    feature_len = add 0, 0
    s4 = add 0, 0
    EXPAND NODE_DIAGNOSTICS_CHANNEL_TOP_FEATURE_SUPPORT_JSON feature_ptr, feature_len, s4
    ok4 = eq s4, 0
    br ok4 -> L_FREE, L_ERR_FEATURES
L_FREE:
    !ok4
    free_feature = call @sa_node_plugin_free_buffer(feature_ptr, feature_len)
    free_factories = call @sa_node_plugin_free_buffer(factories_ptr, factories_len)
    free_exports = call @sa_node_plugin_free_buffer(exports_ptr, exports_len)
    free_status = call @sa_node_plugin_free_buffer(status_ptr, status_len)
    !free_status
    !free_exports
    !free_factories
    !free_feature
    !s4
    !feature_len
    !feature_ptr
    !s3
    !factories_len
    !factories_ptr
    !s2
    !exports_len
    !exports_ptr
    !s1
    !status_len
    !status_ptr
    return
L_ERR_STATUS:
    !ok1
    panic(103)
L_ERR_EXPORTS:
    !ok2
    panic(103)
L_ERR_FACTORIES:
    !ok3
    panic(103)
L_ERR_FEATURES:
    !ok4
    panic(103)
