// Node compatibility plugin public SA macro facade.
@import "node.sai"
@import "node_extra.sai"

[MACRO] NODE_OS_CPUS %out_ptr, %out_len, %out_status
    __c_ptr_slot = stack_alloc 8
    __c_len_slot = stack_alloc 8
    %out_status = call @sa_node_plugin_os_cpus(&__c_ptr_slot, &__c_len_slot)
    %out_ptr = load __c_ptr_slot+0 as ptr
    %out_len = load __c_len_slot+0 as u64
[END_MACRO]

