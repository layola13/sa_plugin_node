@test "node.events on emit count free"():
L_ENTRY:
    EXPAND NODE_EVENTS_CREATE ee
    created = ne ee, 0
    br created -> L_CREATED, L_CREATE_ERR
L_CREATED:
    !created
    cb = stack_alloc 8
    EXPAND NODE_EVENTS_ON ee, S_EVENT, 5, cb, s_on
    ok_on = eq s_on, 0
    br ok_on -> L_ON_OK, L_ON_ERR
L_ON_OK:
    !ok_on
    !s_on
    EXPAND NODE_EVENTS_LISTENER_COUNT ee, S_EVENT, 5, cnt, s_cnt
    ok_cnt = eq s_cnt, 0
    br ok_cnt -> L_COUNT_STATUS_OK, L_COUNT_STATUS_ERR
L_COUNT_STATUS_OK:
    !ok_cnt
    !s_cnt
    count_is_one = eq cnt, 1
    br count_is_one -> L_COUNT_OK, L_COUNT_VALUE_ERR
L_COUNT_OK:
    !count_is_one
    !cnt
    EXPAND NODE_EVENTS_EMIT ee, S_EVENT, 5, S_DATA, 4, s_emit
    ok_emit = eq s_emit, 0
    br ok_emit -> L_EMIT_OK, L_EMIT_ERR
L_EMIT_OK:
    !ok_emit
    !s_emit
    EXPAND NODE_EVENTS_FREE ee, s_free
    ok_free = eq s_free, 0
    br ok_free -> L_OK, L_FREE_ERR
L_OK:
    !ok_free
    !s_free
    !ee
    return
L_CREATE_ERR:
    !created
    !ee
    panic(103)
L_ON_ERR:
    !ok_on
    !s_on
    !ee
    panic(103)
L_COUNT_STATUS_ERR:
    !ok_cnt
    !cnt
    !s_cnt
    !ee
    panic(103)
L_COUNT_VALUE_ERR:
    !count_is_one
    !cnt
    !ee
    panic(103)
L_EMIT_ERR:
    !ok_emit
    !s_emit
    !ee
    panic(103)
L_FREE_ERR:
    !ok_free
    !s_free
    !ee
    panic(103)

@test "node.stream readable writable push write"():
L_ENTRY:
    EXPAND NODE_STREAM_READABLE_NEW r
    r_created = ne r, 0
    br r_created -> L_R_OK, L_R_ERR
L_R_OK:
    !r_created
    EXPAND NODE_STREAM_WRITABLE_NEW w
    w_created = ne w, 0
    br w_created -> L_W_OK, L_W_ERR
L_W_OK:
    !w_created
    EXPAND NODE_STREAM_PUSH r, S_DATA, 4, s_push
    ok_push = eq s_push, 0
    br ok_push -> L_PUSH_OK, L_PUSH_ERR
L_PUSH_OK:
    !ok_push
    !s_push
    EXPAND NODE_STREAM_WRITE w, S_DATA, 4, s_write
    ok_write = eq s_write, 0
    br ok_write -> L_OK, L_WRITE_ERR
L_OK:
    !ok_write
    !s_write
    !r
    !w
    return
L_R_ERR:
    !r_created
    !r
    panic(103)
L_W_ERR:
    !w_created
    !r
    !w
    panic(103)
L_PUSH_ERR:
    !ok_push
    !s_push
    !r
    !w
    panic(103)
L_WRITE_ERR:
    !ok_write
    !s_write
    !r
    !w
    panic(103)

@test "node.string_decoder write free"():
L_ENTRY:
    EXPAND NODE_STRING_DECODER_CREATE sd
    created = ne sd, 0
    br created -> L_CREATED, L_CREATE_ERR
L_CREATED:
    !created
    EXPAND NODE_STRING_DECODER_WRITE s_write, p, l, sd, S_HELLO, 5
    ok_write = eq s_write, 0
    br ok_write -> L_WRITE_OK, L_WRITE_ERR
L_WRITE_OK:
    !ok_write
    !s_write
    expected_len = eq l, 5
    br expected_len -> L_FREE_DECODER, L_LEN_ERR
L_FREE_DECODER:
    !expected_len
    EXPAND NODE_STRING_DECODER_FREE s_free, sd
    ok_free = eq s_free, 0
    br ok_free -> L_OK, L_FREE_ERR
L_OK:
    !ok_free
    !s_free
    !sd
    !p
    !l
    return
L_CREATE_ERR:
    !created
    !sd
    panic(103)
L_WRITE_ERR:
    !ok_write
    !s_write
    !sd
    !p
    !l
    panic(103)
L_LEN_ERR:
    !expected_len
    !sd
    !p
    !l
    panic(103)
L_FREE_ERR:
    !ok_free
    !s_free
    !sd
    !p
    !l
    panic(103)

