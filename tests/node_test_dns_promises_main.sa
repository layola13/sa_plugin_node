// SA compile-surface test for Node dns.promises via the main node.sal facade
@import "../node.sal"

@const S_HOST = utf8:"localhost"
@const S_IP = utf8:"127.0.0.1"
@const S_A = utf8:"A"
@const S_VERBATIM = utf8:"verbatim"

@test "node.dns promises surface compiles from node.sal"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    resolver = add 0, 0

    EXPAND NODE_DNS_PROMISES_LOOKUP p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_CONSTANTS_JSON p, l, s
    EXPAND NODE_DNS_PROMISES_GET_SERVERS p, l, s
    EXPAND NODE_DNS_PROMISES_SET_SERVERS s, 0, 0
    EXPAND NODE_DNS_PROMISES_GET_DEFAULT_RESULT_ORDER p, l, s
    EXPAND NODE_DNS_PROMISES_SET_DEFAULT_RESULT_ORDER s, S_VERBATIM, 8
    EXPAND NODE_DNS_PROMISES_LOOKUP_OPTIONS p, l, s, S_HOST, 9, 4, 1, S_VERBATIM, 8
    EXPAND NODE_DNS_PROMISES_LOOKUP_OPTIONS_HINTS p, l, s, S_HOST, 9, 4, 1, 0, S_VERBATIM, 8
    EXPAND NODE_DNS_PROMISES_LOOKUP_SERVICE p, l, s, S_IP, 9, 80
    EXPAND NODE_DNS_PROMISES_RESOLVE p, l, s, S_HOST, 9, S_A, 1
    EXPAND NODE_DNS_PROMISES_RESOLVE4 p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE6 p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_CNAME p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_MX p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_NS p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_TXT p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_SRV p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_PTR p, l, s, S_IP, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_ANY p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_CAA p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_NAPTR p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_SOA p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVE_TLSA p, l, s, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_REVERSE p, l, s, S_IP, 9

    EXPAND NODE_DNS_PROMISES_RESOLVER_NEW resolver, s, 2000, 2
    EXPAND NODE_DNS_PROMISES_RESOLVER_SET_SERVERS s, resolver, 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVER_GET_SERVERS p, l, s, resolver
    EXPAND NODE_DNS_PROMISES_RESOLVER_SET_LOCAL_ADDRESS s, resolver, 0, 0, 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVER_CANCEL s, resolver
    EXPAND NODE_DNS_PROMISES_RESOLVER_RESOLVE p, l, s, resolver, S_HOST, 9, S_A, 1
    EXPAND NODE_DNS_PROMISES_RESOLVER_RESOLVE4 p, l, s, resolver, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVER_RESOLVE6 p, l, s, resolver, S_HOST, 9
    EXPAND NODE_DNS_PROMISES_RESOLVER_REVERSE p, l, s, resolver, S_IP, 9
    EXPAND NODE_DNS_PROMISES_RESOLVER_SNAPSHOT_JSON p, l, s, resolver
    EXPAND NODE_DNS_PROMISES_RESOLVER_FREE s, resolver

    !resolver
    !s
    !l
    !p
    return
