// SA tests for Node dgram: recv
@import "../node.sal"
@const S_HOST = utf8:"127.0.0.1"
@const S_MSG = utf8:"test"
@const S_EMPTY = utf8:""

@test "node.dgram recv"():
L_ENTRY:
    sock = add 0, 0
    EXPAND NODE_DGRAM_CREATE sock
    s1 = add 0, 0
    EXPAND NODE_DGRAM_BIND s1, sock, S_HOST, 9, 18771
    s2 = add 0, 0
    EXPAND NODE_DGRAM_SEND s2, sock, S_MSG, 4, S_HOST, 9, 18771
    op = add 0, 0
    ol = add 0, 0
    hp = add 0, 0
    hl = add 0, 0
    port = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_DGRAM_RECV s3, op, ol, hp, hl, port, sock, 1024
    s4 = add 0, 0
    EXPAND NODE_DGRAM_SEND s4, sock, S_EMPTY, 0, S_HOST, 9, 18771
    empty_ptr = add 0, 0
    empty_len = add 0, 0
    empty_host_ptr = add 0, 0
    empty_host_len = add 0, 0
    empty_port = add 0, 0
    s5 = add 0, 0
    EXPAND NODE_DGRAM_RECV s5, empty_ptr, empty_len, empty_host_ptr, empty_host_len, empty_port, sock, 1024
    free_empty_host = call @sa_node_plugin_free_buffer(empty_host_ptr, empty_host_len)
    free_empty = call @sa_node_plugin_free_buffer(empty_ptr, empty_len)
    free_host = call @sa_node_plugin_free_buffer(hp, hl)
    free_payload = call @sa_node_plugin_free_buffer(op, ol)
    !free_payload
    !free_host
    !free_empty
    !free_empty_host
    !s5
    !empty_port
    !empty_host_len
    !empty_host_ptr
    !empty_len
    !empty_ptr
    !s4
    !s3
    !port
    !hl
    !hp
    !ol
    !op
    !s2
    !s1
    !sock
    return
