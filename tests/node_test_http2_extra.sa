// SA tests for Node HTTP/2 extras
@import "../node.sal"

@const S_ENABLE_PUSH_FALSE = utf8:"{\"enablePush\":false}"
@const S_H2_CLIENT_PREFACE_SETTINGS = utf8:"PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n\x00\x00\x06\x04\x00\x00\x00\x00\x00\x00\x02\x00\x00\x00\x00"
@const S_IPV6_URL = utf8:"http://[::1]/"
@const S_GET = utf8:"GET"
@const S_POST = utf8:"POST"
@const S_BODY = utf8:"node-body"

@test "node.http2 settings helpers"():
L_ENTRY:
    default_ptr = add 0, 0
    default_len = add 0, 0
    default_status = add 0, 0
    EXPAND NODE_HTTP2_GET_DEFAULT_SETTINGS_JSON default_ptr, default_len, default_status
    default_ok = eq default_status, 0
    br default_ok -> L_DEFAULT_LEN, L_ERR_DEFAULT
L_DEFAULT_LEN:
    !default_ok
    default_has_len = ugt default_len, 0
    br default_has_len -> L_CONSTANTS, L_ERR_DEFAULT_LEN
L_CONSTANTS:
    !default_has_len
    constants_ptr = add 0, 0
    constants_len = add 0, 0
    constants_status = add 0, 0
    EXPAND NODE_HTTP2_CONSTANTS_JSON constants_ptr, constants_len, constants_status
    constants_ok = eq constants_status, 0
    br constants_ok -> L_CONSTANTS_LEN, L_ERR_CONSTANTS
L_CONSTANTS_LEN:
    !constants_ok
    constants_has_len = ugt constants_len, 0
    br constants_has_len -> L_SENSITIVE, L_ERR_CONSTANTS_LEN
L_SENSITIVE:
    !constants_has_len
    sensitive_ptr = add 0, 0
    sensitive_len = add 0, 0
    sensitive_status = add 0, 0
    EXPAND NODE_HTTP2_SENSITIVE_HEADERS sensitive_ptr, sensitive_len, sensitive_status
    sensitive_ok = eq sensitive_status, 0
    br sensitive_ok -> L_SENSITIVE_LEN, L_ERR_SENSITIVE
L_SENSITIVE_LEN:
    !sensitive_ok
    sensitive_has_len = ugt sensitive_len, 0
    br sensitive_has_len -> L_PACK, L_ERR_SENSITIVE_LEN
L_PACK:
    !sensitive_has_len
    packed_ptr = add 0, 0
    packed_len = add 0, 0
    packed_status = add 0, 0
    EXPAND NODE_HTTP2_GET_PACKED_SETTINGS packed_ptr, packed_len, packed_status, S_ENABLE_PUSH_FALSE, 20
    packed_ok = eq packed_status, 0
    br packed_ok -> L_PACK_LEN, L_ERR_PACK
L_PACK_LEN:
    !packed_ok
    packed_len_ok = eq packed_len, 6
    br packed_len_ok -> L_UNPACK, L_ERR_PACK_LEN
L_UNPACK:
    !packed_len_ok
    unpacked_ptr = add 0, 0
    unpacked_len = add 0, 0
    unpacked_status = add 0, 0
    EXPAND NODE_HTTP2_GET_UNPACKED_SETTINGS_JSON unpacked_ptr, unpacked_len, unpacked_status, packed_ptr, packed_len
    unpacked_ok = eq unpacked_status, 0
    br unpacked_ok -> L_UNPACK_LEN, L_ERR_UNPACK
L_UNPACK_LEN:
    !unpacked_ok
    unpacked_has_len = ugt unpacked_len, 0
    br unpacked_has_len -> L_OK, L_ERR_UNPACK_LEN
L_OK:
    !unpacked_has_len
    free_default = call @sa_node_plugin_free_buffer(default_ptr, default_len)
    free_constants = call @sa_node_plugin_free_buffer(constants_ptr, constants_len)
    free_sensitive = call @sa_node_plugin_free_buffer(sensitive_ptr, sensitive_len)
    free_packed = call @sa_node_plugin_free_buffer(packed_ptr, packed_len)
    free_unpacked = call @sa_node_plugin_free_buffer(unpacked_ptr, unpacked_len)
    !free_unpacked
    !free_packed
    !free_sensitive
    !free_constants
    !free_default
    !unpacked_len
    !unpacked_ptr
    !sensitive_len
    !sensitive_ptr
    !constants_len
    !constants_ptr
    !packed_len
    !packed_ptr
    !default_len
    !default_ptr
    return
L_ERR_DEFAULT:
    !default_ok
    !default_status
    panic(103)
L_ERR_DEFAULT_LEN:
    !default_has_len
    !default_ptr
    !default_len
    panic(103)
L_ERR_CONSTANTS:
    !constants_ok
    !constants_status
    panic(103)
L_ERR_CONSTANTS_LEN:
    !constants_has_len
    !constants_ptr
    !constants_len
    panic(103)
L_ERR_SENSITIVE:
    !sensitive_ok
    !sensitive_status
    panic(103)
L_ERR_SENSITIVE_LEN:
    !sensitive_has_len
    !sensitive_ptr
    !sensitive_len
    panic(103)
L_ERR_PACK:
    !packed_ok
    !packed_status
    panic(103)
L_ERR_PACK_LEN:
    !packed_len_ok
    !packed_ptr
    !packed_len
    panic(103)
L_ERR_UNPACK:
    !unpacked_ok
    !unpacked_status
    panic(103)
L_ERR_UNPACK_LEN:
    !unpacked_has_len
    !unpacked_ptr
    !unpacked_len
    panic(103)

@test "node.http2 perform server handshake"():
L_ENTRY:
    bytes_ptr = add 0, 0
    bytes_len = add 0, 0
    json_ptr = add 0, 0
    json_len = add 0, 0
    status = add 0, 0
    EXPAND NODE_HTTP2_PERFORM_SERVER_HANDSHAKE bytes_ptr, bytes_len, json_ptr, json_len, status, S_H2_CLIENT_PREFACE_SETTINGS, 39, S_ENABLE_PUSH_FALSE, 20
    ok = eq status, 0
    br ok -> L_BYTES_LEN, L_ERR_STATUS
L_BYTES_LEN:
    !ok
    bytes_len_ok = eq bytes_len, 24
    br bytes_len_ok -> L_JSON_LEN, L_ERR_BYTES_LEN
L_JSON_LEN:
    !bytes_len_ok
    json_has_len = ugt json_len, 0
    br json_has_len -> L_OK, L_ERR_JSON_LEN
L_OK:
    !json_has_len
    free_bytes = call @sa_node_plugin_free_buffer(bytes_ptr, bytes_len)
    free_json = call @sa_node_plugin_free_buffer(json_ptr, json_len)
    !free_json
    !free_bytes
    !json_len
    !json_ptr
    !bytes_len
    !bytes_ptr
    !status
    return
L_ERR_STATUS:
    !ok
    !status
    panic(103)
L_ERR_BYTES_LEN:
    !bytes_len_ok
    panic(103)
L_ERR_JSON_LEN:
    !json_has_len
    panic(103)

@test "node.http2 client parses bracketed IPv6 h2c URL"():
L_ENTRY:
    out_ptr = add 0, 0
    out_len = add 0, 0
    status = add 0, 0
    EXPAND NODE_HTTP2_CLIENT_REQUEST out_ptr, out_len, status, S_IPV6_URL, 13, S_GET, 3, 0, 0
    ok = eq status, 0
    br ok -> L_LEN, L_ERR_STATUS
L_LEN:
    !ok
    has_len = ugt out_len, 0
    br has_len -> L_OK, L_ERR_LEN
L_OK:
    !has_len
    free_out = call @sa_node_plugin_free_buffer(out_ptr, out_len)
    !free_out
    !status
    !out_len
    !out_ptr
    return
L_ERR_STATUS:
    !ok
    !status
    panic(103)
L_ERR_LEN:
    !has_len
    !out_len
    !out_ptr
    panic(103)

@test "node.http2 client request accepts body argument"():
L_ENTRY:
    out_ptr = add 0, 0
    out_len = add 0, 0
    status = add 0, 0
    EXPAND NODE_HTTP2_CLIENT_REQUEST out_ptr, out_len, status, S_IPV6_URL, 13, S_POST, 4, S_BODY, 9
    ok = eq status, 0
    br ok -> L_LEN, L_ERR_STATUS
L_LEN:
    !ok
    has_len = ugt out_len, 0
    br has_len -> L_OK, L_ERR_LEN
L_OK:
    !has_len
    free_out = call @sa_node_plugin_free_buffer(out_ptr, out_len)
    !free_out
    !status
    !out_len
    !out_ptr
    return
L_ERR_STATUS:
    !ok
    !status
    panic(103)
L_ERR_LEN:
    !has_len
    !out_len
    !out_ptr
    panic(103)
