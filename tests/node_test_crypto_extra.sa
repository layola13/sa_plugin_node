L_CHK:
    !ok3
    !s3
    has_data = ugt fl, 0
    br has_data -> L_FREE, L_DATA_ERR
L_FREE:
    !has_data
    !fp
    !fl
    s4 = add 0, 0
    EXPAND NODE_CRYPTO_HMAC_FREE h, s4
    !h
