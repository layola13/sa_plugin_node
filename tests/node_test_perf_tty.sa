@test "node.perf_hooks create_histogram and free"():
L_ENTRY:
    h = add 0, 0
    p = add 0, 0
    l = add 0, 0
    EXPAND NODE_PERF_HOOKS_CREATE_HISTOGRAM h
    EXPAND NODE_PERF_HOOKS_HISTOGRAM_RECORD h, 42
    EXPAND NODE_PERF_HOOKS_HISTOGRAM_GET_STATISTICS h, p, l
    EXPAND NODE_PERF_HOOKS_HISTOGRAM_FREE h
    !p
    !l
    !h
    return

