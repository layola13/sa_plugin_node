// Tests for zlib, buffer, url, util, path, punycode, querystring extras
@import "../node.sal"

@const S_DATA = utf8:"hello world"
@const S_JSON_A = utf8:"{\"a\":1}"
@const S_URL = utf8:"https://example.com/path?q=1"
@const S_VT = utf8:"\x1b[31mred\x1b[0m"
@const S_PATH = utf8:"/usr/local/bin/test.txt"
@const S_FROM = utf8:"/usr/local/bin"
@const S_TO = utf8:"/usr/local/share"
@const S_QS = utf8:"a=1&b=two"
@const S_DOMAIN = utf8:"münchen.de"
@const S_PUNY = utf8:"mnchen-3ya"
@const S_B64 = utf8:"aGVsbG8="
@const S_ENCODED = utf8:"hello%20world"
@const S_SLASH_A = utf8:"/a"
@const S_SLASH_B = utf8:"/b"
@const S_PATH_JSON = utf8:"{\"dir\":\"/tmp\",\"base\":\"x.txt\"}"
@const S_URL_JSON = utf8:"{\"protocol\":\"https:\",\"host\":\"example.com\",\"pathname\":\"/p\"}"
@const S_GLOB = utf8:"*.sa"

@test "node.zlib inflate roundtrip"():
L_ENTRY:
    dp = add 0, 0
    dl = add 0, 0
    s1 = add 0, 0
    EXPAND NODE_ZLIB_DEFLATE dp, dl, s1, S_DATA, 11
    ok1 = eq s1, 0
    br ok1 -> L_INFLATE, L_ERR1
L_INFLATE:
    !ok1
    !s1
    ip = add 0, 0
    il = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_ZLIB_INFLATE ip, il, s2, dp, dl
    ok2 = eq s2, 0
    br ok2 -> L_CHK, L_ERR2
L_CHK:
    !ok2
    !s2
    !dp
    !dl
    len_ok = eq il, 11
    br len_ok -> L_OK, L_LEN_ERR
L_OK:
    !len_ok
    !ip
    !il
    return
L_ERR1:
    !ok1
    !s1
    panic(103)
L_ERR2:
    !ok2
    !s2
    !dp
    !dl
    !ip
    !il
    panic(103)
L_LEN_ERR:
    !len_ok
    !ip
    !il
    panic(103)

@test "node.zlib gunzip roundtrip"():
