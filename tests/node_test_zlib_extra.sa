// SA tests for Node zlib extras: deflate_raw, brotli_compress, brotli_decompress
@import "../node.sal"
@import "../node_extra.sal"
@const S_DATA = utf8:"hello zlib raw test"

@test "node.zlib deflate_raw"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_ZLIB_DEFLATE_RAW S_DATA, 19, op, ol, s
    !s
    !ol
    !op
    return

@test "node.zlib brotli_compress"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_ZLIB_BROTLI_COMPRESS S_DATA, 19, op, ol, s
    !s
    !ol
    !op
    return

@test "node.zlib brotli_decompress"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    cp = add 0, 0
    cl = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_ZLIB_BROTLI_COMPRESS S_DATA, 19, cp, cl, s1
    EXPAND NODE_ZLIB_BROTLI_DECOMPRESS cp, cl, op, ol, s2
    !s2
    !ol
    !op
    !cl
    !cp
    !s1
    return

@test "node.zlib zstd roundtrip"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    cp = add 0, 0
    cl = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_ZLIB_ZSTD_COMPRESS S_DATA, 19, cp, cl, s1
    EXPAND NODE_ZLIB_ZSTD_DECOMPRESS cp, cl, op, ol, s2
    !s2
    !ol
    !op
    !cl
    !cp
    !s1
    return

@test "node.zlib constants json"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_ZLIB_CONSTANTS_JSON p, l, s
    ok = eq s, 0
    br ok -> L_LEN_CHECK, L_ERR
L_LEN_CHECK:
    !ok
    has_len = gt l, 0
    br has_len -> L_OK, L_LEN_ERR
L_OK:
    !has_len
    !p
    !l
    !s
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !has_len
    !p
    !l
    !s
    panic(103)

@test "node.zlib codes json"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_ZLIB_CODES_JSON p, l, s
    ok = eq s, 0
    br ok -> L_LEN_CHECK, L_ERR
L_LEN_CHECK:
    !ok
    has_len = gt l, 0
    br has_len -> L_OK, L_LEN_ERR
L_OK:
    !has_len
    !p
    !l
    !s
    return
L_ERR:
    !ok
    !p
    !l
    !s
    panic(103)
L_LEN_ERR:
    !has_len
    !p
    !l
    !s
    panic(103)
