@test "node.timers set_timeout and clear"():
L_ENTRY:
    tid = add 0, 0
    s1 = add 0, 0
    s2 = add 0, 0
    EXPAND NODE_TIMERS_SET_TIMEOUT 100, 0, tid, s1
    ok = eq s1, 0
    br ok -> L_CLEAR, L_ERR
L_CLEAR:
    !ok
    !s1
    EXPAND NODE_TIMERS_CLEAR_TIMEOUT tid, s2
    !s2
    !tid
    return
L_ERR:
    !ok
    !s1
    !s2
    !tid
    panic(103)

