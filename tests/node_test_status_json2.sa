// SA tests for 2-param STATUS_JSON macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.cluster status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_CLUSTER_STATUS_JSON op, ol
    !ol
    !op
    return

@test "node.domain status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    EXPAND NODE_DOMAIN_STATUS_JSON op, ol
    !ol
    !op
    return
