// Tests for crypto stateful APIs
@import "../node.sal"
@import "../node_extra.sal"

@const S_SHA256 = utf8:"sha256"
@const S_SECRET = utf8:"secret123"
@const S_DATA = utf8:"hello"

@test "node.crypto create_hash sha256 succeeds"():
L_ENTRY:
    h = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_CREATE_HASH S_SHA256, 6, h, s
    ok = eq s, 0
    br ok -> L_OK, L_ERR
L_OK:
    !ok
    !s
    nonzero = ne h, 0
    br nonzero -> L_FREE, L_H_ERR
L_FREE:
    !nonzero
    s2 = add 0, 0
    EXPAND NODE_CRYPTO_HASH_FREE h, s2
    !h
    return
L_ERR:
    !ok
    !s
    panic(103)
L_H_ERR:
    !nonzero
    !h
    panic(103)

@test "node.crypto hash update and final succeeds"():
L_ENTRY:
    h = add 0, 0
    s = add 0, 0
    EXPAND NODE_CRYPTO_CREATE_HASH S_SHA256, 6, h, s
    ok1 = eq s, 0
    br ok1 -> L_UPD, L_ERR
L_UPD:
    !ok1
    !s
    s2 = add 0, 0
    EXPAND NODE_CRYPTO_HASH_UPDATE h, S_DATA, 5, s2
    ok2 = eq s2, 0
    br ok2 -> L_FIN, L_UPD_ERR
L_FIN:
    !ok2
    !s2
    fp = add 0, 0
    fl = add 0, 0
    s3 = add 0, 0
    EXPAND NODE_CRYPTO_HASH_FINAL h, fp, fl, s3
    ok3 = eq s3, 0
    br ok3 -> L_CHK, L_FIN_ERR
L_CHK:
    !ok3
    !s3
    has_data = ugt fl, 0
    br has_data -> L_FREE, L_DATA_ERR
L_FREE:
    !has_data
    !fp
    !fl
    s4 = add 0, 0
    EXPAND NODE_CRYPTO_HASH_FREE h, s4
    !h
    return
L_ERR:
    !ok1
    !s
    !h
    panic(103)
L_UPD_ERR:
    !ok2
    !s2
    !h
    panic(103)
L_FIN_ERR:
    !ok3
    !s3
    !fp
    !fl
    !h
    panic(103)
L_DATA_ERR:
    !has_data
    !fp
    !fl
    !h
    panic(103)

