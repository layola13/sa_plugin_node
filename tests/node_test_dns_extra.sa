@test "node.dns lookup options succeeds"():
L_ENTRY:
    p = add 0, 0
    l = add 0, 0
    s = add 0, 0
    EXPAND NODE_DNS_LOOKUP_OPTIONS p, l, s, S_LOCALHOST, 9, 4, 1, S_IPV4FIRST, 9
    ok = eq s, 0
    br ok -> L_PROMISES, L_ERR
L_PROMISES:
    !ok
    pp = add 0, 0
    pl = add 0, 0
    ps = add 0, 0
    EXPAND NODE_DNS_PROMISES_LOOKUP_OPTIONS pp, pl, ps, S_LOCALHOST, 9, 4, 0, 0, 0
    promises_ok = eq ps, 0
    br promises_ok -> L_HINTS, L_ERR_PROMISES
L_HINTS:
    !promises_ok
    hp = add 0, 0
    hl = add 0, 0
    hs = add 0, 0
    EXPAND NODE_DNS_LOOKUP_OPTIONS_HINTS hp, hl, hs, S_LOCALHOST, 9, 4, 1, 0, S_VERBATIM, 8
    hints_ok = eq hs, 0
    br hints_ok -> L_PROMISES_HINTS, L_ERR_HINTS
L_PROMISES_HINTS:
    !hints_ok
    php = add 0, 0
    phl = add 0, 0
    phs = add 0, 0
    EXPAND NODE_DNS_PROMISES_LOOKUP_OPTIONS_HINTS php, phl, phs, S_LOCALHOST, 9, 4, 0, 0, 0, 0
    promises_hints_ok = eq phs, 0
    br promises_hints_ok -> L_PROMISES_ANY, L_ERR_PROMISES_HINTS
L_PROMISES_ANY:
    !promises_hints_ok
    pap = add 0, 0
    pal = add 0, 0
    pas = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_ANY pap, pal, pas, S_LOCALHOST, 9
    promises_any_ok = eq pas, 0
    br promises_any_ok -> L_PROMISES_CNAME, L_ERR_PROMISES_ANY
L_PROMISES_CNAME:
    !promises_any_ok
    pcp = add 0, 0
    pcl = add 0, 0
    pcs = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_CNAME pcp, pcl, pcs, S_HOST, 11
    promises_cname_ok = eq pcs, 0
    br promises_cname_ok -> L_PROMISES_MX, L_ERR_PROMISES_CNAME
L_PROMISES_MX:
    !promises_cname_ok
    pmp = add 0, 0
    pml = add 0, 0
    pms = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_MX pmp, pml, pms, S_HOST, 11
    promises_mx_ok = eq pms, 0
    br promises_mx_ok -> L_PROMISES_NS, L_ERR_PROMISES_MX
L_PROMISES_NS:
    !promises_mx_ok
    pnp = add 0, 0
    pnl = add 0, 0
    pns = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_NS pnp, pnl, pns, S_HOST, 11
    promises_ns_ok = eq pns, 0
    br promises_ns_ok -> L_PROMISES_TXT, L_ERR_PROMISES_NS
L_PROMISES_TXT:
    !promises_ns_ok
    ptp = add 0, 0
    ptl = add 0, 0
    pts = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_TXT ptp, ptl, pts, S_HOST, 11
    promises_txt_ok = eq pts, 0
    br promises_txt_ok -> L_PROMISES_SRV, L_ERR_PROMISES_TXT
L_PROMISES_SRV:
    !promises_txt_ok
    psp = add 0, 0
    psl = add 0, 0
    pss = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_SRV psp, psl, pss, S_HOST, 11
    promises_srv_ok = eq pss, 0
    br promises_srv_ok -> L_PROMISES_PTR, L_ERR_PROMISES_SRV
L_PROMISES_PTR:
    !promises_srv_ok
    ppp = add 0, 0
    ppl = add 0, 0
    pps = add 0, 0
    EXPAND NODE_DNS_PROMISES_RESOLVE_PTR ppp, ppl, pps, S_IP, 9
    promises_ptr_ok = eq pps, 0
    br promises_ptr_ok -> L_OK, L_ERR_PROMISES_PTR
L_OK:
    !promises_ptr_ok
    free_p = call @sa_node_plugin_free_buffer(p, l)
    free_pp = call @sa_node_plugin_free_buffer(pp, pl)
    free_hp = call @sa_node_plugin_free_buffer(hp, hl)
    free_php = call @sa_node_plugin_free_buffer(php, phl)
    free_pap = call @sa_node_plugin_free_buffer(pap, pal)
    free_pcp = call @sa_node_plugin_free_buffer(pcp, pcl)
    free_pmp = call @sa_node_plugin_free_buffer(pmp, pml)
    free_pnp = call @sa_node_plugin_free_buffer(pnp, pnl)
    free_ptp = call @sa_node_plugin_free_buffer(ptp, ptl)
    free_psp = call @sa_node_plugin_free_buffer(psp, psl)
    free_ppp = call @sa_node_plugin_free_buffer(ppp, ppl)
    !free_ppp
    !free_psp
    !free_ptp
    !free_pnp
    !free_pmp
    !free_pcp
    !free_pap
    !free_php
    !free_hp
    !free_pp
    !free_p
    !pas
    !pal
    !pap
    !pps
    !ppl
    !ppp
    !pss
    !psl
    !psp
    !pts
    !ptl
    !ptp
    !pns
    !pnl
    !pnp
    !pms
    !pml
    !pmp
    !pcs
    !pcl
    !pcp
    !phs
    !phl
    !php
    !hs
    !hl
    !hp
    !ps
    !pl
    !pp
    !s
    !l
    !p
    return
L_ERR:
    !ok
    panic(103)
L_ERR_PROMISES:
    !promises_ok
    panic(103)
L_ERR_HINTS:
    !hints_ok
    panic(103)
L_ERR_PROMISES_HINTS:
    !promises_hints_ok
    panic(103)
L_ERR_PROMISES_ANY:
    !promises_any_ok
    panic(103)
L_ERR_PROMISES_CNAME:
    !promises_cname_ok
    panic(103)
L_ERR_PROMISES_MX:
    !promises_mx_ok
    panic(103)
L_ERR_PROMISES_NS:
    !promises_ns_ok
    panic(103)
L_ERR_PROMISES_TXT:
    !promises_txt_ok
    panic(103)
L_ERR_PROMISES_SRV:
    !promises_srv_ok
    panic(103)
L_ERR_PROMISES_PTR:
    !promises_ptr_ok
    panic(103)
