// ============================================================
// Zlib
// ============================================================

@test "zlib.gzip"():
    EXPAND NODE_ZLIB_GZIP p, l, s, S_HELLO 5
    ok = eq s, 0
    !ok
    call @sa_node_plugin_free_buffer(p, l)
    !p
    !l
    !s
    return

@test "zlib.roundtrip"():
    EXPAND NODE_ZLIB_GZIP gp, gl, gs, S_HELLO 5
    ok1 = eq gs, 0
    !ok1
    EXPAND NODE_ZLIB_GUNZIP op, ol, os2, gp, gl
    ok2 = eq os2, 0
    !ok2
    call @sa_node_plugin_free_buffer(gp, gl)
    call @sa_node_plugin_free_buffer(op, ol)
    !gp
    !gl
    !gs
    !op
    !ol
    !os2
    !ok1
    !ok2
    return

