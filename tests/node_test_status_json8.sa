// SA tests for more 3-param STATUS_JSON macros
@import "../node.sal"
@import "../node_extra.sal"

@test "node.errors status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_ERRORS_STATUS_JSON op, ol, s
    !s
    !ol
    !op
    return

@test "node.internationalization status_json"():
L_ENTRY:
    op = add 0, 0
    ol = add 0, 0
    s = add 0, 0
    EXPAND NODE_INTERNATIONALIZATION_STATUS_JSON op, ol, s
    !s
    !ol
    !op
    return
